# Variables de entorno de las Netlify Functions de /contratos.
# Copia este archivo a `.env` (ya está en .gitignore) y rellena los valores.
# NUNCA se commitean ni llegan al frontend; solo viven en el servidor.

# ── Anthropic — función de chat (Claude) ──
ANTHROPIC_API_KEY=

# ── ClickUp — función registrar-lead (espacio "LGO Abogados") ──
CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=

# ── Aviso de leads por correo (copia a contacto@lgo.mx) ──
LEAD_EMAIL_TO=contacto@lgo.mx
# Remitente: subdominio verificado en Resend (no-reply@send.lgo.mx).
LEAD_EMAIL_FROM=Asistente de Contratos LGO <no-reply@send.lgo.mx>
RESEND_API_KEY=

# ── Mercado Pago — Checkout Pro (funciones mp-*) ──
# PRUEBA: usa credenciales de TEST y MP_ENV=sandbox.
# PRODUCCIÓN: cambia a las credenciales LIVE (Access Token y Public Key de
#   producción) y MP_ENV=production. El MP_WEBHOOK_SECRET también es por entorno
#   (se genera en Tus integraciones → Webhooks de la app correspondiente).
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
MP_ENV=sandbox
