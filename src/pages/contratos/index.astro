---
import Base from '@layouts/Base.astro';
import AsistenteContratos from '@components/contratos/AsistenteContratos.astro';
import ContratoCard from '@components/contratos/ContratoCard.astro';
import { contratosCatalogo } from '@data/contratos-catalogo';
import { catalogoJsonLd } from '@data/contratos-jsonld';

const title = 'Contratos a la medida | Grupo LGO';
const description =
  'Prepara contratos y documentos legales con el asistente de Grupo LGO: arrendamiento, compraventa, prestación de servicios, poderes, pagarés y más. Descríbenos tu situación y te guiamos.';
const path = '/contratos/';

const contratos = [...contratosCatalogo].sort((a, b) => a.nombre.localeCompare(b.nombre, 'es'));
const total = contratos.length;
const categorias = ['Todos', 'General', 'Negocios'] as const;

// Structured data del catálogo (Breadcrumb + CollectionPage con ItemList).
const jsonLd = catalogoJsonLd();
---
<Base title={title} description={description} path={path} extraJsonLd={jsonLd}>

  <!-- ASISTENTE (puerta de entrada del flujo) -->
  <AsistenteContratos />

  <!-- CATÁLOGO INFORMATIVO (sin precios) -->
  <section class="section band-cream catalogo">
    <div class="container-base">
      <div class="catalogo-head">
        <span class="eyebrow">Catálogo</span>
        <h2>O revisa los documentos disponibles</h2>
        <p class="lead catalogo-lead">
          {total} documentos legales que preparamos en Grupo LGO. Aquí encuentras de qué trata cada uno;
          para prepararlo, usa el asistente de arriba.
        </p>
      </div>

      <div class="cat-toolbar">
        <div class="cat-search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/>
            <path d="M21 21l-4.3-4.3" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
          </svg>
          <input
            type="search"
            class="cat-search-input"
            placeholder="Busca por nombre o tema (renta, préstamo, poder, vehículo…)"
            autocomplete="off"
            aria-label="Buscar documento"
            data-buscar-input
          />
        </div>
        <div class="cat-chips" role="group" aria-label="Filtrar por categoría">
          {categorias.map((cat) => (
            <button
              type="button"
              class:list={['cat-chip', { 'is-active': cat === 'Todos' }]}
              data-cat-chip={cat}
            >{cat}</button>
          ))}
        </div>
      </div>

      <p class="cat-count" data-count aria-live="polite">{total} documentos</p>

      <div class="cat-grid" data-grid>
        {contratos.map((c) => <ContratoCard contrato={c} />)}
      </div>

      <p class="cat-empty" data-empty hidden>
        No encontramos documentos para tu búsqueda. Prueba con otra palabra o pregúntale al asistente.
      </p>
    </div>
  </section>

</Base>

<style>
  .catalogo-head { max-width: 46rem; margin-bottom: 2rem; }
  .catalogo-head h2 { margin: 0.75rem 0 0.75rem; }
  .catalogo-lead { max-width: 44rem; }

  .cat-toolbar {
    display: flex; flex-direction: column; gap: 1rem; margin-bottom: 1.25rem;
  }
  @media (min-width: 768px) {
    .cat-toolbar { flex-direction: row; align-items: center; justify-content: space-between; }
  }

  .cat-search { position: relative; display: flex; align-items: center; flex: 1; max-width: 34rem; }
  .cat-search svg { position: absolute; left: 0.9rem; color: var(--color-muted-soft); pointer-events: none; }
  .cat-search-input {
    width: 100%; font-family: inherit; font-size: var(--text-base);
    padding: 0.8rem 1rem 0.8rem 2.6rem; border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm); background: var(--color-surface);
  }
  .cat-search-input:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 1px; }

  .cat-chips { display: flex; gap: 0.5rem; flex-shrink: 0; }
  .cat-chip {
    font-family: inherit; font-size: var(--text-sm); font-weight: 600;
    padding: 0.55rem 1rem; border: 1px solid var(--color-border-strong);
    border-radius: 999px; background: var(--color-surface); color: var(--color-muted);
    cursor: pointer; transition: all 180ms ease;
  }
  .cat-chip:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .cat-chip.is-active { background: var(--color-accent); border-color: var(--color-accent); color: var(--color-on-accent); }

  .cat-count { font-size: var(--text-sm); color: var(--color-muted); margin: 0 0 1.5rem; }

  .cat-grid { display: grid; grid-template-columns: 1fr; gap: 1.25rem; }
  @media (min-width: 600px)  { .cat-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 980px)  { .cat-grid { grid-template-columns: repeat(3, 1fr); } }
  .cat-grid[hidden] { display: none; }

  .cat-empty { text-align: center; color: var(--color-muted); padding: 3rem 1rem; }
</style>

<script>
  const grid = document.querySelector<HTMLElement>('[data-grid]');
  const input = document.querySelector<HTMLInputElement>('[data-buscar-input]');
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-cat-chip]'));
  const count = document.querySelector<HTMLElement>('[data-count]');
  const empty = document.querySelector<HTMLElement>('[data-empty]');

  if (grid && input && count && empty) {
    const cards = Array.from(grid.querySelectorAll<HTMLElement>('[data-contrato-card]'));
    let categoria = 'Todos';
    let query = '';

    const apply = () => {
      const q = query.trim().toLowerCase();
      let visibles = 0;
      cards.forEach((card) => {
        const matchCat = categoria === 'Todos' || card.dataset.categoria === categoria;
        const matchQ = q === '' || (card.dataset.buscar || '').includes(q);
        const show = matchCat && matchQ;
        card.style.display = show ? '' : 'none';
        if (show) visibles++;
      });
      count.textContent = `${visibles} ${visibles === 1 ? 'documento' : 'documentos'}`;
      empty.hidden = visibles !== 0;
      grid.hidden = visibles === 0;
    };

    input.addEventListener('input', () => { query = input.value; apply(); });
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        categoria = chip.dataset.catChip || 'Todos';
        apply();
      });
    });
  }
</script>
