---
import Base from '@layouts/Base.astro';
import { contratosCatalogo } from '@data/contratos-catalogo';
import { contratoJsonLd, FECHA_REVISION_ISO, FECHA_REVISION_TEXTO } from '@data/contratos-jsonld';
import { documentosRelacionados, linkificarMenciones } from '@data/contratos-clusters';

// Carga de los JSON de campos (explicación, fundamento, flags) en build.
const camposModules = import.meta.glob('../../data/contratos/*.json', { eager: true });

export function getStaticPaths() {
  return contratosCatalogo.map((contrato) => ({
    params: { id: contrato.id },
    props: { contrato }
  }));
}

interface ContratoData {
  id: string;
  nombre: string;
  explicacion: string;
  fundamento_legal: string;
  /** Resumen editorial de apoyo (120-150w) para citabilidad por IA. NO es texto legal verbatim. */
  resumen?: string;
  disclaimer_reforzado?: boolean;
}

const { contrato } = Astro.props;
const mod = camposModules[`../../data/contratos/${contrato.id}.json`] as { default: ContratoData };
const data = mod.default;

const title = `${contrato.nombre} | Contratos Grupo LGO`;
const description = contrato.descripcion_corta;
const path = `/contratos/${contrato.id}/`;

// Structured data por ficha (Breadcrumb + Article + FAQPage). Datos legales verbatim.
const jsonLd = contratoJsonLd(contrato, data);

// ── Render markdown-ligero de la explicación (## , ### , **negrita**, * lista, [a](url)) ──
const esc = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
const inline = (s: string) =>
  esc(s)
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\[([^\]]+)\]\((https?:[^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener">$1</a>');

function mdLite(src: string): string {
  const out: string[] = [];
  let list: string[] = [];
  const flushList = () => {
    if (list.length) { out.push(`<ul class="exp-list">${list.map((li) => `<li>${inline(li)}</li>`).join('')}</ul>`); list = []; }
  };
  // El corpus usa niveles de # inconsistentes (#, ##, ###, #### mezclados para el
  // mismo rango). Se normaliza por SEMÁNTICA, no por número de #: las preguntas de
  // la cabecera (¿Qué es?, ¿Para qué sirve/se usa?, ¿Quiénes…?) son secciones
  // principales (H2); en cuanto aparece una subsección-etiqueta (Requisitos, Dudas
  // frecuentes, Características…) el resto pasa a H3, incluidas las preguntas de FAQ.
  let enSubsecciones = false;
  for (const raw of src.split('\n')) {
    const line = raw.trim();
    if (!line) { flushList(); continue; }
    const h = line.match(/^#{1,6}\s+(.*)$/);
    if (h) {
      flushList();
      const txt = h[1].replace(/\*\*/g, '');
      const esPregunta = /^\s*¿/.test(txt);
      if (esPregunta && !enSubsecciones) {
        out.push(`<h2>${inline(txt)}</h2>`);
      } else {
        if (!esPregunta) enSubsecciones = true;
        out.push(`<h3>${inline(txt)}</h3>`);
      }
    }
    else if (/^[*-]\s+/.test(line)) { list.push(line.replace(/^[*-]\s+/, '')); }
    else { flushList(); out.push(`<p>${inline(line)}</p>`); }
  }
  flushList();
  return out.join('\n');
}
// Enlaces contextuales: convierte en enlaces las menciones de otras fichas
// dentro del texto (sin alterarlo). + lista de documentos relacionados por cluster.
const explicacionHtml = linkificarMenciones(mdLite(data.explicacion), contrato.id);
const relacionados = documentosRelacionados(contrato.id);
---
<Base title={title} description={description} path={path} noindex={true} extraJsonLd={jsonLd}>

  <section class="section-tight">
    <div class="container-narrow">
      <nav class="crumbs" aria-label="Ruta">
        <a href="/contratos/">Contratos</a>
        <span aria-hidden="true">/</span>
        <span>{contrato.nombre}</span>
      </nav>

      <span class={`doc-badge doc-badge--${contrato.categoria.toLowerCase()}`}>{contrato.categoria}</span>
      <h1 class="doc-title">{contrato.nombre}</h1>
      <p class="lead doc-lead">{contrato.descripcion_corta}</p>
      <p class="doc-revision">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M20 6L9 17l-5-5" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Revisado por el equipo jurídico de <strong>LGO Abogados</strong>
        <span aria-hidden="true">·</span>
        <time datetime={FECHA_REVISION_ISO}>{FECHA_REVISION_TEXTO}</time>
      </p>
    </div>
  </section>

  <section class="section-tight doc-body">
    <div class="container-narrow">

      {data.resumen && (
        <div class="doc-enbreve">
          <span class="doc-enbreve-label">En breve</span>
          <p>{data.resumen}</p>
        </div>
      )}

      <div class="doc-grid">
      <!-- Explicación -->
      <article class="doc-explica prose-lgo" set:html={explicacionHtml} />

      <!-- Aside: CTA al asistente + fundamento -->
      <aside class="doc-aside">
        <div class="prep card">
          <span class="prep-eyebrow">¿Es el que necesitas?</span>
          <p class="prep-note">
            Prepáralo con el asistente: te hace unas preguntas, lo llena contigo y lo dejas listo para firmar.
          </p>
          <a href={`/contratos/?doc=${contrato.id}#asistente`} class="btn btn-primary prep-btn">Prepararlo con el asistente →</a>
          {data.disclaimer_reforzado && (
            <p class="prep-warn">
              Este documento toca temas sensibles (menores, pensiones, bienes). Te recomendamos
              asesoría directa del despacho antes de usarlo.
            </p>
          )}
        </div>

        {data.fundamento_legal && (
          <div class="doc-fundamento">
            <span class="doc-fundamento-label">Fundamento legal</span>
            <p>{data.fundamento_legal}</p>
          </div>
        )}
      </aside>
      </div>

      {relacionados.length > 0 && (
        <nav class="doc-relacionados" aria-label="Documentos relacionados">
          <h2 class="doc-relacionados-titulo">Documentos relacionados</h2>
          <ul class="doc-relacionados-lista">
            {relacionados.map((r) => (
              <li><a href={`/contratos/${r.id}/`}>{r.nombre}</a></li>
            ))}
          </ul>
        </nav>
      )}

      <p class="doc-disclaimer">
        Esta información es orientativa y no constituye asesoría jurídica. Cada situación tiene
        particularidades; para tu caso concreto, consulta con un abogado de LGO Abogados.
      </p>
    </div>
  </section>

</Base>

<style>
  .crumbs { display: flex; gap: 0.5rem; align-items: center; font-size: var(--text-sm); color: var(--color-muted); margin-bottom: 1.25rem; }
  .crumbs a { color: var(--color-accent); text-decoration: none; font-weight: 600; }
  .crumbs a:hover { text-decoration: underline; }

  .doc-badge {
    display: inline-flex; font-size: var(--text-eyebrow); letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 700; padding: 0.3rem 0.6rem; border-radius: var(--radius-xs); margin-bottom: 0.85rem;
  }
  .doc-badge--general { background: var(--color-accent-soft); color: var(--color-accent-deep); }
  .doc-badge--negocios { background: var(--color-surface-band); color: var(--color-foreground-strong); border: 1px solid var(--color-border); }

  .doc-title { margin: 0 0 1rem; }
  .doc-lead { max-width: 46rem; }

  /* Byline de revisión jurídica (E-E-A-T / confianza) */
  .doc-revision {
    display: inline-flex; align-items: center; gap: 0.45rem; flex-wrap: wrap;
    font-size: var(--text-sm); color: var(--color-muted); margin: 1rem 0 0;
  }
  .doc-revision svg { color: var(--color-accent); flex-shrink: 0; }
  .doc-revision strong { color: var(--color-foreground-strong); font-weight: 600; }
  .doc-revision time { color: var(--color-muted); }

  /* Bloque "En breve" — resumen de apoyo, citabilidad por IA */
  .doc-enbreve {
    background: var(--color-accent-soft); border-left: 3px solid var(--color-accent);
    border-radius: var(--radius-sm); padding: 1.1rem 1.35rem; margin-bottom: 2.5rem;
    max-width: 52rem;
  }
  .doc-enbreve-label {
    font-size: var(--text-eyebrow); letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 700; color: var(--color-accent-deep); display: block; margin-bottom: 0.4rem;
  }
  .doc-enbreve p { margin: 0; font-size: var(--text-base); line-height: 1.65; color: var(--color-foreground-strong); }

  /* Disclaimer de no-asesoría (YMYL) */
  .doc-disclaimer {
    margin: 2.5rem 0 0; padding-top: 1.25rem; border-top: 1px solid var(--color-border);
    font-size: var(--text-xs); color: var(--color-muted-soft); line-height: 1.6; max-width: 52rem;
  }

  /* Enlaces contextuales dentro de la explicación */
  .doc-explica :global(.exp-link) { color: var(--color-accent); text-decoration: underline; text-underline-offset: 2px; }
  .doc-explica :global(.exp-link):hover { color: var(--color-accent-deep); }

  /* Documentos relacionados (malla interna por cluster temático) */
  .doc-relacionados { margin: 2.75rem 0 0; }
  .doc-relacionados-titulo { font-size: var(--text-lg); margin: 0 0 1rem; }
  .doc-relacionados-lista {
    list-style: none; padding: 0; margin: 0;
    display: grid; gap: 0.65rem; grid-template-columns: 1fr;
  }
  @media (min-width: 600px) { .doc-relacionados-lista { grid-template-columns: 1fr 1fr; } }
  .doc-relacionados-lista a {
    display: block; padding: 0.7rem 0.9rem; border: 1px solid var(--color-border);
    border-radius: var(--radius-sm); color: var(--color-foreground-strong); text-decoration: none;
    font-size: var(--text-sm); font-weight: 600; transition: border-color 180ms ease, color 180ms ease;
  }
  .doc-relacionados-lista a:hover { border-color: var(--color-accent); color: var(--color-accent); }
  .doc-relacionados-lista a::after { content: ' →'; color: var(--color-accent); font-weight: 700; }

  .doc-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; }
  @media (min-width: 960px) { .doc-grid { grid-template-columns: 1fr 20rem; gap: 3.5rem; align-items: start; } }

  /* Explicación */
  .doc-explica :global(h2) { font-size: var(--text-2xl); margin: 2rem 0 0.75rem; }
  .doc-explica :global(h2):first-child { margin-top: 0; }
  .doc-explica :global(h3) { font-size: var(--text-lg); margin: 1.5rem 0 0.5rem; }
  .doc-explica :global(p) { margin-bottom: 0.9rem; }
  .doc-explica :global(.exp-list) { display: flex; flex-direction: column; gap: 0.5rem; margin: 0.5rem 0 1.1rem; padding-left: 1.1rem; }
  .doc-explica :global(.exp-list li) { position: relative; font-size: var(--text-base); color: var(--color-muted); line-height: 1.6; }
  .doc-explica :global(.exp-list li)::before {
    content: ''; position: absolute; left: -1.1rem; top: 0.7em; width: 5px; height: 5px; border-radius: 50%; background: var(--color-accent);
  }
  .doc-explica :global(strong) { color: var(--color-foreground-strong); }

  /* Aside */
  .doc-aside { display: flex; flex-direction: column; gap: 1.5rem; }
  @media (min-width: 960px) { .doc-aside { position: sticky; top: calc(var(--nav-h) + 1.5rem); } }

  .prep { display: flex; flex-direction: column; gap: 0.7rem; }
  .prep-eyebrow {
    font-size: var(--text-eyebrow); letter-spacing: 0.16em; text-transform: uppercase;
    font-weight: 700; color: var(--color-accent);
  }
  .prep-note { font-size: var(--text-sm); color: var(--color-muted); margin: 0; }
  .prep-btn { width: 100%; }
  .prep-warn {
    font-size: var(--text-xs); color: var(--color-accent-deep);
    background: var(--color-accent-soft); border-radius: var(--radius-sm);
    padding: 0.6rem 0.75rem; margin: 0.25rem 0 0; line-height: 1.5;
  }

  .doc-fundamento { border-left: 2px solid var(--color-border-strong); padding-left: 1rem; }
  .doc-fundamento-label {
    font-size: var(--text-eyebrow); letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 700; color: var(--color-muted-soft); display: block; margin-bottom: 0.35rem;
  }
  .doc-fundamento p { font-size: var(--text-sm); color: var(--color-muted); margin: 0; word-break: break-word; }
</style>
