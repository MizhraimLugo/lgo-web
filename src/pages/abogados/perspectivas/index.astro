---
import Base from '@layouts/Base.astro';
import PostCard from '@components/PostCard.astro';
import CtaBand from '@components/CtaBand.astro';
import { business } from '@data/business';
import { postsByBrand } from '@data/perspectivas';
import { getBrand } from '@data/brands';

const brand = getBrand('abogados')!;
const path = '/abogados/perspectivas/';
const title = `Perspectivas legales | ${brand.name}`;
const description =
  'Análisis y contexto sobre derecho corporativo, defensa fiscal, propiedad intelectual y reformas legales que afectan a las empresas en México.';

const posts = await postsByBrand('abogados');

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio',        item: business.url + '/' },
    { '@type': 'ListItem', position: 2, name: brand.shortName, item: business.url + brand.url },
    { '@type': 'ListItem', position: 3, name: 'Perspectivas',  item: business.url + path }
  ]
};

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  url: business.url + path,
  name: title,
  description,
  isPartOf: { '@id': `${business.url}/#website` },
  about: { '@id': `${business.url}/#abogados` }
};
---
<Base title={title} description={description} path={path} extraJsonLd={[breadcrumbLd, collectionLd]}>

  <section class="hero section-roomy">
    <div class="container-base">
      <span class="eyebrow reveal-up reveal-up--immediate">
        <a href={brand.url} class="hero-back">{brand.shortName}</a> · Perspectivas legales
      </span>
      <h1 class="reveal-up reveal-up--immediate">Análisis del equipo legal</h1>
      <p class="lead reveal-up reveal-up--immediate">
        Reformas, criterios judiciales y temas de derecho corporativo que afectan a
        las empresas. Escrito por el equipo de {brand.name}.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-base">
      {posts.length === 0 ? (
        <p class="empty">Aún no hay artículos publicados por esta práctica. Vuelve pronto.</p>
      ) : (
        <div class="posts-grid">
          {posts.map((post) => <PostCard post={post} showBrand={false} />)}
        </div>
      )}
    </div>
  </section>

  <CtaBand
    eyebrow="Hablemos"
    title="¿Necesitas asesoría legal para tu empresa?"
    body="Si tu situación se parece a algo que leíste aquí, conversemos. Sin compromiso."
    primaryLabel="Solicitar consulta"
    primaryHref="/contacto/"
    secondaryLabel="WhatsApp"
    secondaryHref={business.whatsappUrl}
    variant="dark"
  />

</Base>

<style>
  .hero h1 { max-width: 20ch; margin: 1.25rem 0 1.5rem; }
  .hero-back {
    color: inherit;
    text-decoration: none;
    transition: color 200ms ease;
  }
  .hero-back:hover { color: var(--color-accent-deep); }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px)  { .posts-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1100px) { .posts-grid { grid-template-columns: repeat(3, 1fr); } }

  .empty {
    text-align: center;
    color: var(--color-muted);
    padding-block: 4rem;
  }
</style>
