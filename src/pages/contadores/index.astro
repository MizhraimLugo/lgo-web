---
import Base from '@layouts/Base.astro';
import CtaBand from '@components/CtaBand.astro';
import Faq from '@components/Faq.astro';
import Logo from '@components/Logo.astro';
import PostCard from '@components/PostCard.astro';
import ServiceCard from '@components/ServiceCard.astro';
import { business } from '@data/business';
import { getBrand } from '@data/brands';
import { servicesByBrand } from '@data/services';
import { sectores } from '@data/sectores';
import { faqsContadores } from '@data/faqs';
import { postsByBrand } from '@data/perspectivas';

const brand = getBrand('contadores')!;
const path = brand.url;
const title = `${brand.name} | Contabilidad y planeación fiscal en Guadalajara`;
const description =
  'Contabilidad mensual, cumplimiento fiscal ante el SAT, declaraciones anuales y planeación estratégica. Práctica contable integrada con LGO Abogados y operada desde Guadalajara, Jalisco.';

const services = servicesByBrand('contadores');
const posts = (await postsByBrand('contadores')).slice(0, 3);

const serviceLd = services.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.name,
  description: s.blurb,
  provider: { '@id': `${business.url}/#contadores` },
  areaServed: { '@type': 'AdministrativeArea', name: 'Jalisco' }
}));

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqsContadores.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: { '@type': 'Answer', text: a }
  }))
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: business.url + '/' },
    { '@type': 'ListItem', position: 2, name: brand.shortName, item: business.url + brand.url }
  ]
};
---
<Base
  title={title}
  description={description}
  path={path}
  extraJsonLd={[...serviceLd, faqLd, breadcrumbLd]}
>

  <!-- HERO -->
  <section class="hero section-roomy">
    <div class="container-base">
      <div class="hero-logo reveal-up reveal-up--immediate">
        <Logo brand="contadores" height={48} alt={brand.name} />
      </div>
      <h1 class="reveal-up reveal-up--immediate">
        Contabilidad que sirve para decidir, no solo para cumplir.
      </h1>
      <p class="lead reveal-up reveal-up--immediate">
        Práctica contable y fiscal en Guadalajara. Cumplimiento riguroso ante el SAT,
        reportes mensuales en lenguaje claro y planeación que se documenta. Operamos
        junto a LGO Abogados bajo un mismo criterio.
      </p>
      <div class="hero-ctas reveal-up reveal-up--immediate">
        <a href="/contacto/" class="btn btn-primary">Solicitar consulta</a>
        <a href="#servicios" class="btn btn-ghost">Ver servicios</a>
      </div>
    </div>
  </section>

  <!-- QUÉ HACEMOS -->
  <section class="section band-cream">
    <div class="container-base que-hacemos-grid">
      <div>
        <span class="eyebrow">Qué hacemos</span>
        <h2>Tu contador no debería ser quien menos entiendes en la mesa.</h2>
      </div>
      <div class="prose-lgo">
        <p>
          Llevamos la contabilidad mensual de empresas de operación continua: registro,
          conciliación, cierre, declaraciones, atención al SAT. Lo que cambia con
          nosotros es lo que entregamos encima: un tablero ejecutivo en lenguaje claro
          con los números que sí importan para decidir — cuánto vendiste, cuánto cobraste,
          qué quedó, cuánto debes, cuánto pagarás de impuestos este mes.
        </p>
        <p>
          La planeación fiscal viene después del cumplimiento, no antes. Trabajamos solo
          con estrategias que se sostienen por escrito, en ley vigente y que resisten
          revisión. No vendemos esquemas que dependan de huecos temporales o de que
          nadie pregunte.
        </p>
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="section">
    <div class="container-base">
      <header class="section-head">
        <span class="eyebrow">Servicios</span>
        <h2>Cinco frentes de la práctica</h2>
        <p class="lead">
          De la contabilidad mensual operativa a la planeación fiscal estratégica.
          Puedes contratar el paquete completo o servicios puntuales según lo que
          necesite tu empresa.
        </p>
      </header>

      <div class="services-grid">
        {services.map((s, i) => (
          <ServiceCard
            service={s}
            number={String(i + 1).padStart(2, '0')}
            featured={i === 0}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- SECTORES -->
  <section class="section band-cream">
    <div class="container-base">
      <header class="section-head">
        <span class="eyebrow">Sectores con experiencia</span>
        <h2>Conocemos el tratamiento fiscal de tu industria.</h2>
        <p class="lead">
          Cada sector tiene sus propias reglas: regímenes, deducciones, obligaciones
          informativas, calendario fiscal. Estos son los sectores donde tenemos años
          de experiencia operativa.
        </p>
      </header>

      <div class="sectores-grid">
        {sectores.map((sec) => (
          <article class="sector-item">
            <h3 class="sector-name">{sec.name}</h3>
            <p class="sector-detail">{sec.detail}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CÓMO TRABAJAMOS -->
  <section class="section band-dark">
    <div class="container-base como-grid">
      <div>
        <span class="eyebrow">Cómo trabajamos</span>
        <h2>Cuatro principios que ordenan cada cliente.</h2>
      </div>
      <ol class="como-list">
        <li>
          <span class="como-num" aria-hidden="true">01</span>
          <div>
            <h3>Reportes en lenguaje claro</h3>
            <p>El balance y el estado de resultados están disponibles para quien quiera el detalle. La conversación principal es de decisión, no de contabilidad.</p>
          </div>
        </li>
        <li>
          <span class="como-num" aria-hidden="true">02</span>
          <div>
            <h3>Planeación antes del cierre, no después</h3>
            <p>El ahorro fiscal no nace en marzo: nace en cada decisión de compra, contratación y cobranza del año. Revisamos números cada mes para llegar a marzo sin sorpresas.</p>
          </div>
        </li>
        <li>
          <span class="como-num" aria-hidden="true">03</span>
          <div>
            <h3>Cumplimiento riguroso, sin atajos</h3>
            <p>El cumplimiento es la base no negociable. Las planeaciones que ofrecemos se documentan, se sostienen en ley y resisten revisión del SAT.</p>
          </div>
        </li>
        <li>
          <span class="como-num" aria-hidden="true">04</span>
          <div>
            <h3>Coordinación con LGO Abogados</h3>
            <p>Cuando un tema fiscal escala a la autoridad, ya hay un abogado del mismo despacho involucrado en la conversación. Sin coordinación entre firmas distintas.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <!-- PERSPECTIVAS DE CONTADORES -->
  {posts.length > 0 && (
    <section class="section">
      <div class="container-base">
        <header class="section-head section-head--row">
          <div>
            <span class="eyebrow">Perspectivas fiscales</span>
            <h2>Últimos análisis del equipo contable</h2>
          </div>
          <a href="/contadores/perspectivas/" class="head-link">Ver todos los artículos →</a>
        </header>
        <div class="perspectivas-grid">
          {posts.map((p) => <PostCard post={p} showBrand={false} />)}
        </div>
      </div>
    </section>
  )}

  <!-- FAQ -->
  <section class="section band-cream">
    <div class="container-base">
      <Faq items={faqsContadores} title="Preguntas frecuentes" />
    </div>
  </section>

  <!-- CTA -->
  <CtaBand
    eyebrow="Hablemos"
    title="Una primera conversación, sin compromiso"
    body="Cuéntanos cómo está hoy tu contabilidad o qué temas fiscales tienes pendientes. Te respondemos con propuesta y siguientes pasos."
    primaryLabel="Solicitar consulta"
    primaryHref="/contacto/"
    secondaryLabel="WhatsApp"
    secondaryHref={business.whatsappUrl}
    variant="dark"
  />

</Base>

<style>
  .hero-logo { margin-bottom: 1.5rem; }
  .hero h1 { max-width: 20ch; margin: 0 0 1.5rem; }
  .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 2rem; }

  .section-head {
    margin-bottom: 2.5rem;
    max-width: 38rem;
  }
  .section-head h2 { margin: 1rem 0 0.75rem; max-width: 22ch; }
  .section-head .lead { max-width: 52ch; }

  .section-head--row {
    max-width: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: end;
  }
  @media (min-width: 1024px) {
    .section-head--row { grid-template-columns: 1fr auto; gap: 3rem; }
  }
  .head-link {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
    padding-block: 0.5rem;
  }
  .head-link:hover { color: var(--color-accent-deep); }

  .que-hacemos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .que-hacemos-grid h2 { max-width: 22ch; }
  @media (min-width: 1024px) {
    .que-hacemos-grid { grid-template-columns: 1fr 1.4fr; gap: 5rem; }
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) { .services-grid { grid-template-columns: repeat(2, 1fr); } }

  .sectores-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px)  { .sectores-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .sectores-grid { grid-template-columns: repeat(3, 1fr); } }
  .sector-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1.5rem;
    transition: border-color 200ms ease;
  }
  .sector-item:hover { border-color: var(--color-accent); }
  .sector-name {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-foreground-strong);
    margin: 0 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .sector-detail {
    font-size: var(--text-xs);
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0;
  }

  .como-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: start;
  }
  .como-grid h2 { max-width: 18ch; margin: 1rem 0; }

  .como-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  .como-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  .como-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 3rem;
    height: 3rem;
    background: rgba(212,84,26,0.18);
    color: var(--color-accent-soft);
    font-size: 0.95rem;
    font-weight: 700;
    border-radius: var(--radius-xs);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .como-list h3 {
    font-size: 1.125rem;
    margin: 0 0 0.5rem;
    color: var(--color-on-dark);
    letter-spacing: -0.01em;
  }
  .como-list p {
    font-size: 0.9375rem;
    color: rgba(250,248,244,0.78);
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }
  @media (min-width: 1024px) {
    .como-grid { grid-template-columns: 1fr 1.5fr; gap: 5rem; }
    .como-list { grid-template-columns: 1fr 1fr; gap: 2rem 2.5rem; }
  }

  .perspectivas-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px)  { .perspectivas-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1100px) { .perspectivas-grid { grid-template-columns: repeat(3, 1fr); } }
</style>
