---
import Base from '@layouts/Base.astro';
import CourseCard from '@components/CourseCard.astro';
import CtaBand from '@components/CtaBand.astro';
import { business } from '@data/business';
import { cursos, featuredCourse, nonFeaturedCourses } from '@data/cursos-preview';

const title = 'Cursos y herramientas | Grupo LGO';
const description =
  'Diagnósticos gratuitos, cursos online y masterclasses presenciales del ecosistema Grupo LGO. Aprende cómo decidimos y aplícalo a tu negocio.';
const path = '/cursos/';

const featured = featuredCourse();
const others = nonFeaturedCourses();

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: business.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Cursos', item: business.url + path }
  ]
};

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: cursos.map((c, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: business.url + c.url,
    name: c.name
  }))
};
---
<Base title={title} description={description} path={path} extraJsonLd={[breadcrumbLd, itemListLd]}>

  <section class="hero section-roomy">
    <div class="container-base">
      <span class="eyebrow reveal-up reveal-up--immediate">Cursos y herramientas</span>
      <h1 class="reveal-up reveal-up--immediate">Aprende cómo decidimos. Aplícalo a tu negocio.</h1>
      <p class="lead reveal-up reveal-up--immediate">
        Tres formatos para tres maneras de aprender. Empieza por el diagnóstico
        gratuito si quieres saber dónde está tu negocio antes de invertir en cualquier otro paso.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container-base">

      {featured && (
        <div class="cursos-featured-wrap">
          <CourseCard course={featured} layout="featured" />
        </div>
      )}

      <div class="cursos-grid">
        {others.map((c) => (
          <CourseCard course={c} layout="standard" />
        ))}
      </div>

    </div>
  </section>

  <!-- LOS TRES FORMATOS -->
  <section class="section band-cream">
    <div class="container-base formats-grid">
      <div>
        <span class="eyebrow">Tres formatos</span>
        <h2>Cada uno para un momento distinto.</h2>
      </div>
      <ul class="formats-list">
        <li>
          <span class="format-badge format-badge--gratuito">Gratuito</span>
          <div>
            <strong>Diagnósticos y herramientas.</strong> Cuestionarios interactivos
            para autoevaluar tu situación. Sin compromiso. Te quedas con un resultado
            personalizado y, si quieres, un consultor te contacta.
          </div>
        </li>
        <li>
          <span class="format-badge format-badge--online">Online</span>
          <div>
            <strong>Contenido grabado, a tu ritmo.</strong> Módulos compactos que
            puedes ver cuando puedas, con plantillas y checklists descargables.
            Pago único, acceso permanente.
          </div>
        </li>
        <li>
          <span class="format-badge format-badge--presencial">Presencial</span>
          <div>
            <strong>Masterclasses en Lorenzana 781.</strong> Sesiones intensivas
            con cupo limitado, en nuestra casa empresarial de Guadalajara. Material
            impreso, comida, networking.
          </div>
        </li>
      </ul>
    </div>
  </section>

  <CtaBand
    eyebrow="Empresas"
    title="¿Quieres una formación a medida para tu equipo?"
    body="Diseñamos programas internos para directores, mandos medios y equipos administrativos. Cuéntanos qué necesitas."
    primaryLabel="Solicitar cotización"
    primaryHref="/contacto/"
    secondaryLabel="WhatsApp"
    secondaryHref={business.whatsappUrl}
    variant="dark"
  />

</Base>

<style>
  .hero h1 { max-width: 22ch; margin: 1.25rem 0 1.5rem; }

  .cursos-featured-wrap { margin-bottom: 1.25rem; }

  .cursos-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 720px) { .cursos-grid { grid-template-columns: repeat(2, 1fr); } }

  /* LOS TRES FORMATOS */
  .formats-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  .formats-grid h2 { max-width: 18ch; }

  .formats-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .formats-list li {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem 1.5rem;
    align-items: start;
    padding: 1.25rem 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
  }
  .formats-list strong {
    color: var(--color-foreground-strong);
    font-weight: 700;
    display: block;
    margin-bottom: 0.25rem;
  }
  .formats-list > li > div {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
  }

  .format-badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-eyebrow);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-xs);
    align-self: start;
    white-space: nowrap;
  }
  .format-badge--gratuito {
    background: var(--color-accent-soft);
    color: var(--color-accent-deep);
  }
  .format-badge--online {
    background: var(--color-surface-band);
    color: var(--color-foreground-strong);
    border: 1px solid var(--color-border);
  }
  .format-badge--presencial {
    background: var(--color-foreground-strong);
    color: var(--color-on-dark);
  }

  @media (min-width: 1024px) {
    .formats-grid { grid-template-columns: 1fr 1.6fr; gap: 5rem; }
  }
</style>
