---
import Base from '@layouts/Base.astro';
import { business } from '@data/business';
import {
  territorios,
  TOTAL_PREGUNTAS,
  SCORE_MAX_TOTAL,
  OPCIONES_RESPUESTA
} from '@data/diagnostico';

const path = '/cursos/diagnostico-salud-fiscal/';
const title = 'Diagnóstico de Salud Fiscal | Grupo LGO';
const description =
  'Cincuenta preguntas que tu negocio debe poder contestar. Diagnóstico gratuito en cinco territorios: orden financiero, régimen fiscal, utilidad y flujo, riesgos cotidianos, socios y patrimonio.';

// FormSubmit AJAX endpoint — sin redirect, response JSON.
// Tras el primer envío manual con activación, todos los envíos posteriores
// llegan a contacto@lgo.mx sin pasar por el cliente.
const formAjaxEndpoint = `https://formsubmit.co/ajax/${business.email}`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: business.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Cursos', item: business.url + '/cursos/' },
    { '@type': 'ListItem', position: 3, name: 'Diagnóstico de Salud Fiscal', item: business.url + path }
  ]
};

const courseLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: 'Diagnóstico de Salud Fiscal',
  description,
  url: business.url + path,
  provider: { '@id': `${business.url}/#organization` },
  inLanguage: 'es-MX',
  isAccessibleForFree: true,
  educationalLevel: 'Empresarios y directivos',
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'MXN',
    availability: 'https://schema.org/InStock'
  },
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: 'online',
    courseWorkload: 'PT10M'
  }
};
---
<Base
  title={title}
  description={description}
  path={path}
  extraJsonLd={[breadcrumbLd, courseLd]}
>

  <!-- HERO -->
  <section class="hero section-roomy">
    <div class="container-base hero-grid">
      <div>
        <span class="eyebrow reveal-up reveal-up--immediate">Diagnóstico gratuito · 10 minutos</span>
        <h1 class="reveal-up reveal-up--immediate">
          Cincuenta preguntas que tu negocio debe poder contestar.
        </h1>
        <p class="lead reveal-up reveal-up--immediate">
          Auto-diagnóstico en cinco territorios de salud fiscal. Al final recibes un
          puntaje, un nivel de salud y una recomendación.
        </p>
        <div class="hero-ctas reveal-up reveal-up--immediate">
          <a href="#gate" class="btn btn-primary">Empezar diagnóstico</a>
        </div>
      </div>
      <aside class="hero-aside reveal-up reveal-up--immediate">
        <div class="hero-stat">
          <div class="hero-stat-num">{TOTAL_PREGUNTAS}</div>
          <div class="hero-stat-label">preguntas</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">{territorios.length}</div>
          <div class="hero-stat-label">territorios</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat-num">~10</div>
          <div class="hero-stat-label">minutos</div>
        </div>
      </aside>
    </div>
  </section>

  <!-- GATE: form de captura ANTES del cuestionario -->
  <section id="gate" class="section band-cream" data-gate-section>
    <div class="container-narrow">
      <header class="gate-head">
        <span class="eyebrow">Antes de empezar</span>
        <h2>Cuéntanos quién eres</h2>
        <p class="lead">
          Necesitamos saber con quién hablamos. Tomamos un minuto en capturar tus
          datos básicos y desbloqueamos el diagnóstico. Tus datos quedan solo con
          Grupo LGO — no se comparten ni se publican.
        </p>
      </header>

      <form id="gate-form" class="gate-form" novalidate>
        <div class="row">
          <div class="field">
            <label for="gate-name">Nombre completo <span aria-hidden="true">*</span></label>
            <input id="gate-name" name="name" type="text" required autocomplete="name" aria-required="true" />
          </div>
          <div class="field">
            <label for="gate-empresa">Empresa <span aria-hidden="true">*</span></label>
            <input id="gate-empresa" name="empresa" type="text" required autocomplete="organization" aria-required="true" />
          </div>
        </div>
        <div class="row">
          <div class="field">
            <label for="gate-phone">Teléfono / WhatsApp <span aria-hidden="true">*</span></label>
            <input id="gate-phone" name="phone" type="tel" required autocomplete="tel" inputmode="tel" aria-required="true" />
          </div>
          <div class="field">
            <label for="gate-email">Correo electrónico <span aria-hidden="true">*</span></label>
            <input id="gate-email" name="email" type="email" required autocomplete="email" aria-required="true" />
          </div>
        </div>

        <p id="gate-error" class="gate-error" hidden></p>

        <button type="submit" class="btn btn-primary gate-submit" data-gate-submit>
          Acceder al diagnóstico →
        </button>
        <p class="gate-helper">
          Al continuar aceptas que un consultor de Grupo LGO pueda contactarte si tu
          diagnóstico lo amerita. Sin spam, sin compromiso.
        </p>
      </form>
    </div>
  </section>

  <!-- BARRA DE PROGRESO STICKY (oculta hasta gate completado) -->
  <div class="progress-bar" data-progress-bar role="status" aria-live="polite" hidden>
    <div class="container-base progress-inner">
      <div class="progress-meta">
        <span class="progress-count">
          <strong data-progress-answered>0</strong> de {TOTAL_PREGUNTAS} respondidas
        </span>
        <span class="progress-score">
          Puntaje: <strong data-progress-score>0</strong> / {SCORE_MAX_TOTAL}
        </span>
      </div>
      <div class="progress-track">
        <div class="progress-fill" data-progress-fill style="width: 0%"></div>
      </div>
    </div>
  </div>

  <!-- CUESTIONARIO (oculto hasta gate completado) -->
  <section id="cuestionario" class="section" data-cuestionario-section hidden>
    <div class="container-base">
      <header class="cuestionario-head">
        <span class="eyebrow">El diagnóstico</span>
        <h2>Cinco territorios. Diez preguntas cada uno.</h2>
        <p class="lead">
          Contesta con honestidad: "Sí", "Parcial", "No" o "No sé". El cuestionario
          se guarda en tu navegador, puedes pausar y volver.
        </p>
      </header>

      <form id="diagnostico-form" class="diagnostico" data-diagnostico>
        {territorios.map((t) => (
          <details class="territorio" data-territorio-id={t.id} open>
            <summary class="territorio-summary">
              <div class="territorio-head">
                <span class="territorio-num">{t.num}</span>
                <div>
                  <h3 class="territorio-name">{t.fullTitle}</h3>
                  <p class="territorio-oneline">"{t.oneLine}"</p>
                </div>
              </div>
              <div class="territorio-meta">
                <span class="territorio-score">
                  <strong data-territorio-score={t.id}>0</strong>/<span>20</span>
                </span>
                <svg class="territorio-chevron" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                  <path d="M3 5l4 4 4-4" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            </summary>

            <div class="territorio-body">
              <p class="territorio-pitch">{t.pitch}</p>

              <ol class="preguntas">
                {t.questions.map((q, qi) => {
                  const name = `t${t.id}_q${qi}`;
                  return (
                    <li class="pregunta" data-pregunta>
                      <p class="pregunta-text">{q}</p>
                      <div class="pregunta-options" role="radiogroup" aria-label={q}>
                        {OPCIONES_RESPUESTA.map((opt) => (
                          <label class="opcion" data-val={opt.val}>
                            <input
                              type="radio"
                              name={name}
                              value={opt.val}
                              data-respuesta
                              data-territorio={t.id}
                            />
                            <span>{opt.label}</span>
                          </label>
                        ))}
                        <label class="opcion opcion--nose">
                          <input
                            type="radio"
                            name={name}
                            value="nose"
                            data-respuesta
                            data-territorio={t.id}
                            data-nose
                          />
                          <span>No sé</span>
                        </label>
                      </div>
                    </li>
                  );
                })}
              </ol>
            </div>
          </details>
        ))}

        <div class="resultado-cta">
          <button type="button" class="btn btn-primary btn-resultado" data-mostrar-resultado>
            Ver mi diagnóstico
          </button>
          <p class="resultado-helper">
            Puedes verlo en cualquier momento. Las preguntas sin responder cuentan como cero.
          </p>
        </div>
      </form>
    </div>
  </section>

  <!-- RESULTADO (oculto hasta calcular) -->
  <section id="resultado" class="section band-cream" hidden data-resultado-section>
    <div class="container-base">
      <header class="resultado-head">
        <span class="eyebrow">Tu diagnóstico</span>
        <h2 data-resultado-titulo>Resultado: <span class="resultado-nivel"></span></h2>
      </header>

      <div class="resultado-card" data-resultado-card>
        <div class="resultado-score">
          <div class="resultado-score-num">
            <span data-resultado-score>0</span>
            <span class="resultado-score-max">/ {SCORE_MAX_TOTAL}</span>
          </div>
          <div class="resultado-score-label" data-resultado-label>—</div>
        </div>
        <p class="resultado-desc" data-resultado-desc>—</p>

        <div class="resultado-breakdown" data-resultado-breakdown>
          {territorios.map((t) => (
            <div class="breakdown-item">
              <div class="breakdown-num">{t.num}</div>
              <div class="breakdown-body">
                <div class="breakdown-name">{t.name}</div>
                <div class="breakdown-score">
                  <strong data-breakdown-score={t.id}>0</strong>/20
                </div>
              </div>
              <div class="breakdown-bar">
                <div class="breakdown-fill" data-breakdown-fill={t.id} style="width: 0%"></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- CTA opcional: solicitar llamada con consultor -->
      <article class="cta-final">
        <header>
          <span class="eyebrow">¿Quieres revisar tu caso con un consultor?</span>
          <h3 data-cta-titulo>Conversemos sobre tu resultado.</h3>
          <p class="cta-helper">
            Ya tienes tu diagnóstico. Si quieres entender qué significa para tu
            negocio en particular y qué hacer con él, un consultor de Grupo LGO
            puede revisarlo contigo en una llamada de 30 minutos sin compromiso.
          </p>
        </header>

        <div class="cta-actions">
          <a href={business.whatsappUrl} target="_blank" rel="noopener" class="btn btn-primary">
            Agendar llamada por WhatsApp
          </a>
          <a href={`mailto:${business.email}?subject=Diagn%C3%B3stico%20de%20Salud%20Fiscal`} class="btn btn-ghost">
            Escribir por correo
          </a>
        </div>

        <p class="cta-already">
          Tu diagnóstico ya está en nuestro sistema. Si prefieres esperar a que
          nosotros te contactemos, lo haremos en horario hábil.
        </p>
      </article>
    </div>
  </section>

</Base>

<style>
  /* HERO */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: center;
  }
  .hero h1 { max-width: 22ch; margin: 1.25rem 0 1.5rem; }
  .hero-ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.75rem; }

  .hero-aside {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .hero-stat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 1.25rem 1rem;
    text-align: center;
  }
  .hero-stat-num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-foreground-strong);
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .hero-stat-label {
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-top: 0.35rem;
  }

  @media (min-width: 1024px) {
    .hero-grid { grid-template-columns: 1.5fr 1fr; gap: 4rem; }
  }

  /* GATE */
  .gate-head { margin-bottom: 2.5rem; text-align: center; }
  .gate-head h2 { margin: 1rem 0 0.75rem; max-width: 22ch; margin-inline: auto; }
  .gate-head .lead { max-width: 50ch; margin-inline: auto; }

  .gate-form {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 4px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 2rem 2.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .gate-form .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 560px) { .gate-form .row { grid-template-columns: 1fr 1fr; } }

  .gate-form .field { display: flex; flex-direction: column; gap: 0.4rem; }
  .gate-form label {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--color-foreground-strong);
  }
  .gate-form label span { color: var(--color-accent); margin-left: 2px; }
  .gate-form input {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-foreground-strong);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    padding: 0.7rem 0.9rem;
    width: 100%;
    transition: border-color 200ms ease, box-shadow 200ms ease;
  }
  .gate-form input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(212,84,26,0.12);
  }
  .gate-form input.is-error {
    border-color: var(--color-alert);
  }

  .gate-error {
    background: rgba(177,70,56,0.08);
    border-left: 3px solid var(--color-alert);
    padding: 0.75rem 1rem;
    border-radius: var(--radius-xs);
    color: var(--color-alert);
    font-size: var(--text-sm);
    margin: 0;
  }

  .gate-submit {
    align-self: flex-start;
    padding: 1rem 2rem;
    font-size: 1rem;
    margin-top: 0.5rem;
  }
  .gate-submit:disabled { opacity: 0.6; cursor: not-allowed; }

  .gate-helper {
    font-size: var(--text-xs);
    color: var(--color-muted);
    line-height: 1.55;
    margin: 0;
    max-width: 56ch;
  }

  /* PROGRESS BAR STICKY */
  .progress-bar {
    position: sticky;
    top: var(--nav-h);
    z-index: 100;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    padding-block: 0.75rem;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .progress-inner { display: flex; flex-direction: column; gap: 0.5rem; }
  .progress-meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    font-size: var(--text-xs);
    color: var(--color-muted);
    letter-spacing: 0.02em;
  }
  .progress-meta strong {
    color: var(--color-foreground-strong);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: var(--text-sm);
  }
  .progress-track {
    height: 6px;
    background: var(--color-surface-band);
    border-radius: 3px;
    overflow: hidden;
  }
  .progress-fill {
    height: 100%;
    background: var(--color-accent);
    transition: width 200ms ease;
  }

  /* CUESTIONARIO */
  .cuestionario-head { margin-bottom: 2.5rem; max-width: 44rem; }
  .cuestionario-head h2 { margin: 1rem 0 0.75rem; max-width: 22ch; }
  .cuestionario-head .lead { max-width: 56ch; }

  .diagnostico { display: flex; flex-direction: column; gap: 1rem; }

  /* TERRITORIO */
  .territorio {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  .territorio-summary {
    list-style: none;
    cursor: pointer;
    padding: 1.5rem 1.75rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    transition: background 200ms ease;
  }
  .territorio-summary::-webkit-details-marker { display: none; }
  .territorio-summary:hover { background: var(--color-surface-alt); }

  .territorio-head { display: flex; align-items: center; gap: 1rem; flex: 1; min-width: 0; }
  .territorio-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: var(--color-accent-soft);
    color: var(--color-accent-deep);
    font-size: 0.875rem;
    font-weight: 700;
    border-radius: var(--radius-xs);
    font-variant-numeric: tabular-nums;
    flex-shrink: 0;
  }
  .territorio-name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-foreground-strong);
    margin: 0 0 0.25rem;
    letter-spacing: -0.012em;
    line-height: 1.25;
  }
  .territorio-oneline {
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin: 0;
    font-style: italic;
  }
  .territorio-meta { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; }
  .territorio-score { font-size: var(--text-sm); color: var(--color-muted); font-variant-numeric: tabular-nums; }
  .territorio-score strong { color: var(--color-foreground-strong); font-weight: 700; }
  .territorio-chevron { transition: transform 200ms ease; color: var(--color-muted); }
  .territorio[open] .territorio-chevron { transform: rotate(180deg); }

  .territorio-body {
    padding: 0 1.75rem 1.75rem;
    border-top: 1px solid var(--color-divider);
  }
  .territorio-pitch {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
    margin: 1.25rem 0 1.75rem;
    max-width: 60ch;
    font-style: italic;
  }

  /* PREGUNTAS */
  .preguntas { display: flex; flex-direction: column; gap: 1rem; counter-reset: pregunta; }
  .pregunta {
    counter-increment: pregunta;
    padding: 1rem 0;
    border-top: 1px solid var(--color-divider);
  }
  .pregunta:first-child { border-top: none; }
  .pregunta-text {
    font-size: var(--text-base);
    color: var(--color-foreground);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }
  .pregunta-text::before {
    content: counter(pregunta) ". ";
    color: var(--color-accent);
    font-weight: 700;
    margin-right: 0.25rem;
  }
  .pregunta-options { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .opcion {
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    padding: 0.55rem 1rem;
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-xs);
    font-size: var(--text-sm);
    color: var(--color-muted);
    background: transparent;
    transition: all 150ms ease;
    user-select: none;
    min-height: 40px;
  }
  .opcion input { position: absolute; opacity: 0; pointer-events: none; }
  .opcion:hover { border-color: var(--color-accent); color: var(--color-foreground-strong); }
  .opcion:has(input:checked) {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: var(--color-on-accent);
    font-weight: 700;
  }
  .opcion--nose:has(input:checked) {
    background: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  /* CTA Ver resultado */
  .resultado-cta {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-divider);
    text-align: center;
  }
  .btn-resultado { padding: 1rem 2.5rem; font-size: 1rem; }
  .resultado-helper { font-size: var(--text-xs); color: var(--color-muted); margin-top: 1rem; }

  /* RESULTADO */
  .resultado-head { margin-bottom: 2rem; max-width: 44rem; }
  .resultado-head h2 { margin: 1rem 0 0; max-width: 26ch; }
  .resultado-nivel { color: var(--color-accent); }

  .resultado-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 4px solid var(--resultado-color, var(--color-accent));
    border-radius: var(--radius-sm);
    padding: 2rem 2.25rem;
    margin-bottom: 1.5rem;
  }
  .resultado-score {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-divider);
    margin-bottom: 1.5rem;
  }
  .resultado-score-num {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 700;
    line-height: 1;
    color: var(--resultado-color, var(--color-foreground-strong));
    font-variant-numeric: tabular-nums;
    letter-spacing: -0.02em;
  }
  .resultado-score-max {
    font-size: 1rem;
    color: var(--color-muted);
    font-weight: 500;
    margin-left: 0.25rem;
  }
  .resultado-score-label {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--resultado-color, var(--color-accent));
    padding: 0.45rem 0.85rem;
    background: var(--color-accent-soft);
    border-radius: var(--radius-xs);
  }
  .resultado-desc {
    font-size: var(--text-base);
    line-height: 1.65;
    color: var(--color-foreground);
    margin: 0 0 2rem;
    max-width: 60ch;
  }

  .resultado-breakdown {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-divider);
  }
  @media (min-width: 720px) { .resultado-breakdown { grid-template-columns: 1fr 1fr; } }
  .breakdown-item {
    display: grid;
    grid-template-columns: auto 1fr;
    grid-template-rows: auto auto;
    gap: 0.25rem 1rem;
    align-items: center;
    padding: 0.75rem 0;
  }
  .breakdown-num {
    grid-row: 1 / span 2;
    width: 2rem;
    height: 2rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-accent-soft);
    color: var(--color-accent-deep);
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: var(--radius-xs);
    font-variant-numeric: tabular-nums;
  }
  .breakdown-body {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .breakdown-name { font-size: var(--text-sm); font-weight: 600; color: var(--color-foreground-strong); }
  .breakdown-score { font-size: var(--text-xs); color: var(--color-muted); font-variant-numeric: tabular-nums; }
  .breakdown-bar {
    grid-column: 2;
    height: 4px;
    background: var(--color-surface-band);
    border-radius: 2px;
    overflow: hidden;
  }
  .breakdown-fill { height: 100%; background: var(--color-accent); transition: width 400ms ease; }

  /* CTA FINAL — opcional al final del resultado */
  .cta-final {
    background: var(--color-foreground-strong);
    color: var(--color-on-dark);
    border-radius: var(--radius-sm);
    padding: 2.5rem;
    border-top: 4px solid var(--color-accent);
  }
  .cta-final header { margin-bottom: 1.5rem; }
  .cta-final .eyebrow { color: var(--color-accent-soft); }
  .cta-final .eyebrow::before { background: var(--color-accent-soft); }
  .cta-final h3 {
    color: var(--color-on-dark);
    margin: 0.75rem 0 0.75rem;
    font-size: 1.5rem;
    letter-spacing: -0.015em;
  }
  .cta-helper {
    font-size: var(--text-sm);
    color: rgba(250,248,244,0.8);
    line-height: 1.65;
    max-width: 60ch;
  }
  .cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .cta-final .btn-ghost {
    color: var(--color-on-dark);
    border-color: rgba(250,248,244,0.4);
  }
  .cta-final .btn-ghost:hover {
    background: rgba(250,248,244,0.08);
    border-color: var(--color-on-dark);
    color: var(--color-on-dark);
  }
  .cta-already {
    font-size: var(--text-xs);
    color: rgba(250,248,244,0.55);
    margin: 0;
    line-height: 1.55;
  }
</style>

<script define:vars={{ formAjaxEndpoint, business }}>
  // ════════════════════════════════════════════════════════════════
  //  DIAGNÓSTICO INTERACTIVO — Flujo con gate + AJAX
  // ════════════════════════════════════════════════════════════════
  //
  // Flujo:
  //   1. Usuario llega → ve gate de captura (nombre, empresa, tel, email)
  //   2. Envía gate → datos van a FormSubmit vía AJAX (1er lead)
  //                → se guardan en localStorage
  //                → se desbloquea el cuestionario
  //   3. Contesta preguntas → scoring en vivo
  //   4. Pulsa "Ver mi diagnóstico" → muestra resultado
  //                                → envía 2do lead a FormSubmit con diagnóstico
  //                                → CTA opcional para agendar llamada
  //
  // Persistencia:
  //   - lgo_diagnostico_user: datos del gate (si están, saltamos gate)
  //   - lgo_diagnostico_v1:   respuestas del cuestionario

  const STORAGE_USER = 'lgo_diagnostico_user';
  const STORAGE_ANSWERS = 'lgo_diagnostico_v1';

  // ─── Selectores ───
  const gateSection = document.querySelector('[data-gate-section]');
  const gateForm = document.querySelector('#gate-form');
  const gateError = document.querySelector('#gate-error');
  const gateSubmit = document.querySelector('[data-gate-submit]');

  const progressBar = document.querySelector('[data-progress-bar]');
  const cuestionarioSection = document.querySelector('[data-cuestionario-section]');
  const resultadoSection = document.querySelector('[data-resultado-section]');

  const radios = Array.from(document.querySelectorAll('[data-respuesta]'));
  const territorioEls = Array.from(document.querySelectorAll('[data-territorio-id]'));
  const btnResultado = document.querySelector('[data-mostrar-resultado]');

  const progressAnswered = document.querySelector('[data-progress-answered]');
  const progressScore = document.querySelector('[data-progress-score]');
  const progressFill = document.querySelector('[data-progress-fill]');

  const resultadoScoreEl = document.querySelector('[data-resultado-score]');
  const resultadoLabelEl = document.querySelector('[data-resultado-label]');
  const resultadoDescEl = document.querySelector('[data-resultado-desc]');
  const resultadoCard = document.querySelector('[data-resultado-card]');
  const resultadoTituloNivelEl = document.querySelector('.resultado-nivel');
  const ctaTituloEl = document.querySelector('[data-cta-titulo]');

  // ─── Semáforo ───
  const SEMAFORO = {
    sano: {
      label: 'SANO',
      desc: 'Tu negocio muestra una base fiscal y administrativa razonablemente ordenada. Te recomendamos mantener revisiones preventivas, especialmente si vas a crecer, contratar personal, comprar activos o asociarte.',
      color: 'var(--color-success)'
    },
    vigilar: {
      label: 'VIGILAR',
      desc: 'Hay puntos que conviene mejorar antes de que se vuelvan costosos. Recomendamos una revisión de las áreas con menor puntaje y un plan de orden a 3-6 meses.',
      color: 'var(--color-accent)'
    },
    atender: {
      label: 'ATENDER',
      desc: 'Es posible que estés pagando de más, deduciendo mal o usando una estructura que ya no corresponde. Recomendamos una revisión preventiva con prioridad para evitar contingencias mayores.',
      color: 'var(--color-accent-deep)'
    },
    prioritario: {
      label: 'PRIORITARIO',
      desc: 'Tus respuestas reflejan áreas sensibles que pueden generar riesgos fiscales, contables o patrimoniales. No es para alarmarse — es para ordenar. Conversemos antes de que el problema escale.',
      color: 'var(--color-alert)'
    }
  };
  const semaforoFromScore = (score) => {
    if (score >= 80) return 'sano';
    if (score >= 60) return 'vigilar';
    if (score >= 40) return 'atender';
    return 'prioritario';
  };

  const TOTAL_PREGUNTAS = radios.length / 4;

  // ─── Persistencia ───
  const saveUser = (data) => {
    try { localStorage.setItem(STORAGE_USER, JSON.stringify(data)); } catch {}
  };
  const loadUser = () => {
    try { return JSON.parse(localStorage.getItem(STORAGE_USER) || 'null'); } catch { return null; }
  };
  const saveAnswers = () => {
    try {
      const payload = {};
      radios.forEach((r) => { if (r.checked) payload[r.name] = r.value; });
      localStorage.setItem(STORAGE_ANSWERS, JSON.stringify(payload));
    } catch {}
  };
  const loadAnswers = () => {
    try {
      const raw = localStorage.getItem(STORAGE_ANSWERS);
      if (!raw) return;
      const payload = JSON.parse(raw);
      Object.entries(payload).forEach(([name, val]) => {
        const radio = document.querySelector(`input[name="${name}"][value="${val}"]`);
        if (radio) radio.checked = true;
      });
    } catch {}
  };

  // ─── Cálculo de scores ───
  const computeScores = () => {
    const territorios = new Map();
    let total = 0;
    let answered = 0;
    radios.forEach((r) => {
      if (!r.checked) return;
      const tid = parseInt(r.dataset.territorio, 10);
      const t = territorios.get(tid) || { id: tid, score: 0, answered: 0 };
      t.answered += 1;
      answered += 1;
      const val = r.value === 'nose' ? 0 : parseInt(r.value, 10);
      t.score += val;
      total += val;
      territorios.set(tid, t);
    });
    territorioEls.forEach((el) => {
      const tid = parseInt(el.dataset.territorioId, 10);
      if (!territorios.has(tid)) territorios.set(tid, { id: tid, score: 0, answered: 0 });
    });
    return {
      total, answered,
      perTerritorio: Array.from(territorios.values()).sort((a, b) => a.id - b.id)
    };
  };

  const renderLive = () => {
    const { total, answered, perTerritorio } = computeScores();
    if (progressAnswered) progressAnswered.textContent = String(answered);
    if (progressScore) progressScore.textContent = String(total);
    if (progressFill) progressFill.style.width = `${Math.round((answered / TOTAL_PREGUNTAS) * 100)}%`;
    perTerritorio.forEach(({ id, score }) => {
      const el = document.querySelector(`[data-territorio-score="${id}"]`);
      if (el) el.textContent = String(score);
    });
  };

  // ─── Envío AJAX a FormSubmit ───
  const enviarLead = async (payload, subject) => {
    try {
      const body = { ...payload, _subject: subject, _template: 'table' };
      const res = await fetch(formAjaxEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify(body)
      });
      const json = await res.json().catch(() => ({}));
      return res.ok && (json.success === 'true' || json.success === true || res.status === 200);
    } catch {
      return false;
    }
  };

  // ─── Gate (captura inicial) ───
  const desbloquearCuestionario = () => {
    gateSection.hidden = true;
    progressBar.hidden = false;
    cuestionarioSection.hidden = false;
    // Scroll suave al primer territorio
    cuestionarioSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  // Si ya hay usuario capturado en localStorage, saltamos el gate.
  const usuarioGuardado = loadUser();
  if (usuarioGuardado && usuarioGuardado.email) {
    desbloquearCuestionario();
  }

  if (gateForm) {
    gateForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      gateError.hidden = true;

      const data = {
        name: gateForm.name.value.trim(),
        empresa: gateForm.empresa.value.trim(),
        phone: gateForm.phone.value.trim(),
        email: gateForm.email.value.trim()
      };

      // Validación básica
      const inputs = [gateForm.name, gateForm.empresa, gateForm.phone, gateForm.email];
      let invalid = false;
      inputs.forEach((inp) => {
        if (!inp.value.trim() || (inp.type === 'email' && !inp.checkValidity())) {
          inp.classList.add('is-error');
          invalid = true;
        } else {
          inp.classList.remove('is-error');
        }
      });
      if (invalid) {
        gateError.textContent = 'Revisa los campos marcados. Todos son obligatorios.';
        gateError.hidden = false;
        return;
      }

      gateSubmit.disabled = true;
      gateSubmit.textContent = 'Procesando...';

      const ok = await enviarLead(
        { ...data, etapa: 'Inició diagnóstico (1/2)' },
        `Diagnóstico de Salud Fiscal — Lead inició (${data.empresa})`
      );

      // Aunque FormSubmit falle, dejamos al usuario continuar (no bloquear UX)
      saveUser(data);
      gateSubmit.textContent = 'Acceder al diagnóstico →';
      gateSubmit.disabled = false;
      desbloquearCuestionario();
    });
  }

  // ─── Listeners del cuestionario ───
  radios.forEach((r) => {
    r.addEventListener('change', () => {
      saveAnswers();
      renderLive();
    });
  });

  // ─── Resultado ───
  const renderResultado = async () => {
    const { total, answered, perTerritorio } = computeScores();
    const nivel = semaforoFromScore(total);
    const cfg = SEMAFORO[nivel];

    if (resultadoScoreEl) resultadoScoreEl.textContent = String(total);
    if (resultadoLabelEl) resultadoLabelEl.textContent = cfg.label;
    if (resultadoDescEl) resultadoDescEl.textContent = cfg.desc;
    if (resultadoTituloNivelEl) resultadoTituloNivelEl.textContent = cfg.label;
    if (resultadoCard) resultadoCard.style.setProperty('--resultado-color', cfg.color);
    if (ctaTituloEl) {
      ctaTituloEl.textContent = nivel === 'prioritario' || nivel === 'atender'
        ? 'Tu diagnóstico amerita una conversación.'
        : 'Conversemos sobre tu resultado.';
    }

    perTerritorio.forEach(({ id, score }) => {
      const scoreEl = document.querySelector(`[data-breakdown-score="${id}"]`);
      const fillEl = document.querySelector(`[data-breakdown-fill="${id}"]`);
      if (scoreEl) scoreEl.textContent = String(score);
      if (fillEl) fillEl.style.width = `${Math.round((score / 20) * 100)}%`;
    });

    resultadoSection.removeAttribute('hidden');
    resultadoSection.scrollIntoView({ behavior: 'smooth', block: 'start' });

    // Enviar segundo lead con diagnóstico
    const user = loadUser() || {};
    const breakdownStr = perTerritorio.map(({ id, score }) => {
      const el = document.querySelector(`[data-territorio-id="${id}"] .territorio-name`);
      const name = el?.textContent?.trim() || `Territorio ${id}`;
      return `${name}: ${score}/20`;
    }).join(' · ');

    await enviarLead({
      ...user,
      etapa: 'Completó diagnóstico (2/2)',
      diagnostico_score: `${total} / 100`,
      diagnostico_nivel: cfg.label,
      diagnostico_respondidas: `${answered} / ${TOTAL_PREGUNTAS}`,
      diagnostico_breakdown: breakdownStr
    }, `Diagnóstico completado — ${cfg.label} (${user.empresa || 'sin empresa'})`);
  };

  if (btnResultado) {
    btnResultado.addEventListener('click', renderResultado);
  }

  // ─── Bootstrap ───
  loadAnswers();
  renderLive();
</script>
