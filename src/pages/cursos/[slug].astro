---
// Plantilla dinámica para todos los cursos del catálogo, excepto los que
// tienen su propia página personalizada (Diagnóstico).
//
// Para cada curso en cursos-preview.ts (sin customPage), genera una
// página landing con hero + descripción extendida + outcomes + lista de
// espera. Cuando el curso esté disponible, solo cambia el formatLabel
// y el CTA en cursos-preview.ts.

import Base from '@layouts/Base.astro';
import { business } from '@data/business';
import { cursos, templatedCourses, type Course } from '@data/cursos-preview';

export async function getStaticPaths() {
  return templatedCourses().map((course) => ({
    params: { slug: course.slug },
    props: { course }
  }));
}

interface Props { course: Course }
const { course } = Astro.props;

const path = course.url;
const title = `${course.name} | Curso de Grupo LGO`;
const description = course.blurb;

const formEndpoint = `https://formsubmit.co/${business.email}`;

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: business.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Cursos', item: business.url + '/cursos/' },
    { '@type': 'ListItem', position: 3, name: course.name, item: business.url + path }
  ]
};

const courseLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: course.name,
  description: course.blurb,
  url: business.url + path,
  provider: { '@id': `${business.url}/#organization` },
  inLanguage: 'es-MX',
  educationalLevel: course.audience,
  hasCourseInstance: {
    '@type': 'CourseInstance',
    courseMode: course.format === 'presencial' ? 'onsite' : 'online'
  }
};

const subjectLabel =
  course.format === 'presencial' ? 'Reserva' :
  course.format === 'online' ? 'Lista de espera' :
  'Inscripción';
---
<Base title={title} description={description} path={path} extraJsonLd={[breadcrumbLd, courseLd]}>

  <!-- HERO -->
  <section class="hero section-roomy">
    <div class="container-base">
      <span class="eyebrow reveal-up reveal-up--immediate">{course.formatLabel}</span>
      <h1 class="reveal-up reveal-up--immediate">{course.name}</h1>
      <p class="lead reveal-up reveal-up--immediate">{course.blurb}</p>
    </div>
  </section>

  <!-- QUÉ APRENDES + LISTA DE ESPERA -->
  <section class="section band-cream">
    <div class="container-base soon-grid">

      <!-- Columna izquierda: descripción larga + outcomes -->
      <div class="prose-lgo">
        <span class="eyebrow">Para quién</span>
        <h2>{course.audience}</h2>

        {course.longDescription?.map((para) => (
          <p>{para}</p>
        ))}

        {course.outcomes && course.outcomes.length > 0 && (
          <>
            <h3 class="outcomes-title">Lo que te llevas al terminar</h3>
            <ul class="outcomes-list">
              {course.outcomes.map((item) => (
                <li>
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                    <polyline points="2,8 6,12 14,4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </>
        )}
      </div>

      <!-- Columna derecha: lista de espera -->
      <aside class="lista-espera">
        <div class="lista-espera-card">
          <span class="eyebrow">{subjectLabel}</span>
          <h3>Apúntate a la lista de espera</h3>
          <p>
            Te avisamos en cuanto abramos inscripciones. Sin spam, sin promociones
            cruzadas. Solo el aviso cuando el curso esté disponible.
          </p>
          <form
            class="ws-form"
            action={formEndpoint}
            method="POST"
            enctype="application/x-www-form-urlencoded"
            novalidate
          >
            <input
              type="text"
              name="name"
              required
              autocomplete="name"
              placeholder="Tu nombre completo"
              aria-required="true"
              aria-label="Nombre"
            />
            <input
              type="email"
              name="email"
              required
              autocomplete="email"
              placeholder="tu@correo.com"
              aria-required="true"
              aria-label="Correo electrónico"
            />
            <input
              type="tel"
              name="phone"
              autocomplete="tel"
              placeholder="WhatsApp (opcional)"
              aria-label="WhatsApp"
            />
            <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
            <input type="hidden" name="curso" value={course.name} />
            <input type="hidden" name="_subject" value={`${subjectLabel} — ${course.name}`} />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" data-next-redirect />
            <button type="submit" class="btn btn-primary">{course.cta}</button>
          </form>
        </div>
      </aside>

    </div>
  </section>

  <section class="section">
    <div class="container-base">
      <p class="back-link"><a href="/cursos/">← Ver todos los cursos</a></p>
    </div>
  </section>

</Base>

<style>
  .hero h1 { max-width: 26ch; margin: 1.25rem 0 1.5rem; }

  .soon-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    align-items: start;
  }
  @media (min-width: 1024px) {
    .soon-grid { grid-template-columns: 1.5fr 1fr; gap: 4rem; }
  }

  .prose-lgo h2 {
    margin: 1rem 0 1.5rem;
    max-width: 24ch;
  }
  .prose-lgo p {
    margin-bottom: 1.25rem;
    max-width: 64ch;
    line-height: 1.7;
  }

  .outcomes-title {
    margin-top: 2.5rem;
    font-size: 1.25rem;
    letter-spacing: -0.012em;
  }
  .outcomes-list {
    list-style: none;
    padding: 0;
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .outcomes-list li {
    display: grid;
    grid-template-columns: 22px 1fr;
    gap: 0.75rem;
    align-items: start;
    font-size: var(--text-sm);
    line-height: 1.6;
    max-width: 60ch;
  }
  .outcomes-list svg {
    color: var(--color-accent);
    margin-top: 4px;
    flex-shrink: 0;
  }

  /* LISTA DE ESPERA */
  .lista-espera-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 2rem 1.75rem;
    position: sticky;
    top: calc(var(--nav-h) + 1rem);
  }
  .lista-espera-card h3 {
    margin: 0.75rem 0;
    font-size: 1.375rem;
    letter-spacing: -0.012em;
  }
  .lista-espera-card p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .ws-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .ws-form input[type="text"],
  .ws-form input[type="email"],
  .ws-form input[type="tel"] {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    padding: 0.7rem 0.9rem;
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
  }
  .ws-form input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(212,84,26,0.12);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-accent);
  }
  .back-link a {
    text-decoration: none;
    color: inherit;
    font-weight: 600;
  }
  .back-link a:hover { color: var(--color-accent-deep); }
</style>

<script>
  document.querySelectorAll<HTMLInputElement>('[data-next-redirect]').forEach((el) => {
    el.value = `${window.location.origin}/gracias/`;
  });
</script>
