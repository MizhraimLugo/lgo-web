---
import Logo from '@components/Logo.astro';
import { business } from '@data/business';
import { nav } from '@data/nav';
import { brands, publishedSubBrands } from '@data/brands';

const year = 2026;  // estampado en build; actualizar manualmente (no Date.now por workflow)
const lorenzana = brands.find((b) => b.id === 'lorenzana');
---
<footer class="site-footer">
  <div class="container-base footer-grid">

    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label={`${business.brand} — Inicio`}>
        <Logo brand="grupo" height={44} alt={business.brand} />
      </a>
      <p class="footer-tagline">{business.tagline}</p>
      <p class="footer-address">{business.address.full}</p>
    </div>

    <div>
      <div class="footer-col-title">Ecosistema</div>
      <ul class="footer-nav footer-ecosistema">
        {publishedSubBrands.map((b) => (
          <li>
            <a href={b.url} class="footer-ecosistema-item">
              <Logo brand={b.id as any} height={26} alt={b.name} />
              <span class="sr-only">{b.name}</span>
            </a>
          </li>
        ))}
        {lorenzana && (
          <li>
            <a href={lorenzana.url} target="_blank" rel="noopener" class="footer-ecosistema-text">
              Lorenzana 781 <span aria-hidden="true">↗</span>
            </a>
          </li>
        )}
      </ul>
    </div>

    <div>
      <div class="footer-col-title">Navegación</div>
      <ul class="footer-nav">
        {nav.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <div class="footer-col-title">Contacto</div>
      <ul class="footer-nav">
        <li><a href={`mailto:${business.email}`}>{business.email}</a></li>
        <li><a href={`tel:${business.phoneE164}`}>{business.phone}</a></li>
        <li><a href={business.whatsappUrl} target="_blank" rel="noopener">WhatsApp</a></li>
        <li class="footer-hours">{business.hours.label}</li>
      </ul>
    </div>

  </div>

  <div class="container-base footer-bottom">
    <span>© {year} {business.brand}. Todos los derechos reservados.</span>
    <span>{business.address.locality}, {business.address.region}, {business.address.country}</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-foreground-strong);
    color: var(--color-on-dark);
    padding-block: 3.5rem 2rem;
    border-top: 3px solid var(--color-accent);
    margin-top: 4rem;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 640px)  { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1024px) { .footer-grid { grid-template-columns: 2fr 1.2fr 1fr 1.2fr; } }

  /* Logo del footer (sobre fondo oscuro: contenedor blanco para el PNG). */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 0.75rem;
    background: var(--color-surface);
    border-radius: var(--radius-sm);
    margin-bottom: 1rem;
    text-decoration: none;
    transition: opacity 200ms ease;
  }
  .footer-logo:hover { opacity: 0.85; }

  .footer-tagline {
    font-size: var(--text-sm);
    color: rgba(250,248,244,0.65);
    max-width: 30ch;
    margin-bottom: 0.75rem;
    line-height: 1.55;
  }
  .footer-address {
    font-size: var(--text-xs);
    color: rgba(250,248,244,0.55);
    line-height: 1.55;
  }

  .footer-col-title {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(250,248,244,0.45);
    font-weight: 700;
    margin-bottom: 1rem;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .footer-nav a {
    font-size: var(--text-sm);
    color: rgba(250,248,244,0.78);
    text-decoration: none;
    transition: color 200ms ease;
  }
  .footer-nav a:hover { color: var(--color-on-dark); }

  /* Items del ecosistema con logo: contenedor blanco para el PNG sobre fondo oscuro */
  .footer-ecosistema { gap: 0.75rem; }
  .footer-ecosistema-item {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.7rem;
    background: var(--color-surface);
    border-radius: var(--radius-xs);
    transition: opacity 200ms ease;
    align-self: flex-start;
  }
  .footer-ecosistema-item:hover { opacity: 0.85; }
  .footer-ecosistema-text {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    color: rgba(250,248,244,0.78);
    text-decoration: none;
    padding-block: 0.4rem;
  }
  .footer-ecosistema-text:hover { color: var(--color-on-dark); }

  .footer-hours {
    font-size: var(--text-xs);
    color: rgba(250,248,244,0.55);
    margin-top: 0.25rem;
  }

  .footer-bottom {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(250,248,244,0.1);
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: space-between;
    font-size: var(--text-xs);
    color: rgba(250,248,244,0.38);
  }
</style>
