---
import type { Service } from '@data/services';

export interface Props {
  service: Service;
  number: string;       // "01", "02", ... — orden visible en la card
  featured?: boolean;   // primera card, ancho completo, layout horizontal en desktop
  href?: string;        // por defecto vacío (Fase 2 no tiene página de servicio individual)
}

const { service, number, featured = false, href = '/contacto/' } = Astro.props;
const Element = (href ? 'a' : 'article') as 'a' | 'article';
---
<Element
  class={`service-card service-card--${featured ? 'featured' : 'standard'}`}
  href={href}
>
  <div class="service-header">
    <span class="service-number" aria-hidden="true">{number}</span>
    <h3 class="service-name">{service.name}</h3>
  </div>

  <div class="service-body">
    <p class="service-blurb">{service.blurb}</p>
  </div>

  {href && (
    <div class="service-footer">
      <span class="service-cta">Consultar →</span>
    </div>
  )}
</Element>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
    height: 100%;
  }
  .service-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  /* Featured: layout horizontal en desktop con padding generoso */
  .service-card--featured {
    padding: 2.25rem;
    grid-column: 1 / -1;
  }
  @media (min-width: 900px) {
    .service-card--featured {
      display: grid;
      grid-template-columns: 1fr 1.4fr auto;
      gap: 2rem 3rem;
      align-items: center;
      padding: 2.5rem 3rem;
    }
    .service-card--featured .service-header { grid-column: 1; }
    .service-card--featured .service-body { grid-column: 2; }
    .service-card--featured .service-footer { grid-column: 3; align-self: center; }
  }

  .service-header {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-number {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.2em;
    color: var(--color-accent);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .service-name {
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--color-foreground-strong);
    margin: 0;
  }
  .service-card--featured .service-name {
    font-size: 1.5rem;
    line-height: 1.2;
    letter-spacing: -0.018em;
    max-width: 14ch;
  }

  .service-body { flex: 1; }
  .service-blurb {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.65;
    margin: 0;
    max-width: 56ch;
  }
  .service-card--featured .service-blurb {
    font-size: 1rem;
    line-height: 1.7;
  }

  .service-footer {
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-divider);
    margin-top: auto;
  }
  .service-card--featured .service-footer {
    border-top: none;
    padding-top: 0;
  }

  .service-cta {
    display: inline-flex;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
  }
  .service-card--featured .service-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.75rem 1.75rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-radius: var(--radius-sm);
    transition: background 200ms ease;
    white-space: nowrap;
  }
  .service-card--featured:hover .service-cta {
    background: var(--color-accent-hover);
  }
</style>
