---
import type { ContratoCatalogo } from '@data/contratos-catalogo';

export interface Props {
  contrato: ContratoCatalogo;
}

const { contrato } = Astro.props;
const { id, nombre, categoria, descripcion_corta, keywords, tier } = contrato;

// Términos para el buscador en vivo (client-side): nombre + categoría + keywords + descripción.
// Solo información — sin precios (el precio se muestra al pagar, tras el asistente).
const haystack = [nombre, categoria, ...keywords, descripcion_corta].join(' ').toLowerCase();
---
<a
  href={`/contratos/${id}/`}
  class="contrato-card"
  data-contrato-card
  data-buscar={haystack}
  data-categoria={categoria}
  data-tier={tier}
>
  <div class="cc-top">
    <span class={`cc-badge cc-badge--${categoria.toLowerCase()}`}>{categoria}</span>
  </div>
  <h3 class="cc-nombre">{nombre}</h3>
  <p class="cc-desc">{descripcion_corta}</p>
  <span class="cc-cta">Ver información →</span>
</a>

<style>
  .contrato-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
  }
  .contrato-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
  }

  .cc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .cc-badge {
    font-size: var(--text-eyebrow);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.3rem 0.6rem;
    border-radius: var(--radius-xs);
    white-space: nowrap;
  }
  .cc-badge--general {
    background: var(--color-accent-soft);
    color: var(--color-accent-deep);
  }
  .cc-badge--negocios {
    background: var(--color-surface-band);
    color: var(--color-foreground-strong);
    border: 1px solid var(--color-border);
  }

  .cc-precio {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-foreground-strong);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .cc-nombre {
    font-size: 1.0625rem;
    font-weight: 700;
    line-height: 1.3;
    letter-spacing: -0.012em;
    color: var(--color-foreground-strong);
    margin: 0;
  }

  .cc-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
    /* Recorta a 4 líneas para uniformar alturas */
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .cc-cta {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
    margin-top: auto;
  }
</style>
