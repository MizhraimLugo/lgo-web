---
// Asistente de contratos — pieza central del flujo /contratos.
// 1) Puerta de registro: nombre, teléfono y correo (lead para Grupo LGO,
//    NO datos del contrato). Hasta no completarlo, el chat está bloqueado.
// 2) Chat (PASO 3): la IA identifica/recomienda el documento y LLENA sus
//    campos conversando (form-filling vía tool use en netlify/functions/chat).
// 3) Panel de progreso: muestra en vivo los datos que se van capturando.
// 4) Al completar: resumen + botón para enviar el documento al despacho
//    (netlify/functions/registrar-documento → ClickUp + correo).
import { business } from '@data/business';
---
<section class="asistente" id="asistente" data-asistente>
  <div class="container-narrow">
    <span class="eyebrow reveal-up reveal-up--immediate">Asistente de contratos</span>
    <h1 class="asistente-title reveal-up reveal-up--immediate">
      Cuéntanos qué necesitas. Te decimos el documento exacto.
    </h1>
    <p class="lead asistente-lead reveal-up reveal-up--immediate">
      No tienes que saber cómo se llama el contrato. Describe tu situación y el asistente
      de Grupo LGO te guía, lo prepara contigo y lo dejas listo para firmar.
    </p>

    <div class="asistente-panel reveal-up reveal-up--immediate">

      <!-- 1) PUERTA DE REGISTRO -->
      <div class="gate" data-gate>
        <div class="gate-head">
          <h2 class="gate-title">Empecemos</h2>
          <p class="gate-note">
            Déjanos tus datos para darte seguimiento. Son para el registro de Grupo LGO,
            <strong>no aparecen en tu contrato</strong>.
          </p>
        </div>
        <form class="gate-form" data-gate-form novalidate>
          <div class="gf-field">
            <label for="lead-nombre">Nombre completo</label>
            <input id="lead-nombre" name="nombre" type="text" autocomplete="name" required />
          </div>
          <div class="gf-field">
            <label for="lead-tel">Teléfono (WhatsApp)</label>
            <input id="lead-tel" name="telefono" type="tel" inputmode="tel" autocomplete="tel"
              placeholder="10 dígitos" required />
          </div>
          <div class="gf-field">
            <label for="lead-correo">Correo electrónico</label>
            <input id="lead-correo" name="correo" type="email" autocomplete="email" required />
          </div>
          <p class="gf-error" data-gate-error hidden></p>
          <button type="submit" class="btn btn-primary gate-btn">Iniciar conversación →</button>
          <p class="gate-legal">
            Al continuar aceptas que Grupo LGO te contacte sobre tu solicitud.
          </p>
        </form>
      </div>

      <!-- 2) CHAT + PANEL (ocultos hasta registrar) -->
      <div class="chat-wrap" data-chat hidden>
        <div class="chat">
          <header class="chat-head">
            <div class="chat-id">
              <span class="chat-dot" aria-hidden="true"></span>
              <div>
                <strong>Asistente de contratos</strong>
                <span>Grupo LGO · normalmente responde al instante</span>
              </div>
            </div>
            <a href={business.whatsappUrl} target="_blank" rel="noopener" class="chat-wa" data-wa>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2a10 10 0 0 0-8.5 15.3L2 22l4.8-1.5A10 10 0 1 0 12 2Zm5.3 14.2c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .1-1.7-.1-.4-.1-1-.3-1.6-.6-2.9-1.2-4.7-4.1-4.9-4.3-.1-.2-1.1-1.5-1.1-2.8 0-1.3.7-2 .9-2.2.2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 1.9c.1.2.1.4 0 .5l-.3.5-.4.4c-.1.1-.3.3-.1.5.1.3.7 1.1 1.4 1.8.9.8 1.7 1.1 2 1.2.2.1.4.1.5-.1l.6-.7c.2-.2.3-.2.6-.1l1.8.9c.3.1.4.2.5.3.1.2.1.6-.1 1.1Z"/>
              </svg>
              WhatsApp
            </a>
          </header>

          <div class="chat-log" data-chat-log aria-live="polite"></div>

          <form class="chat-form" data-chat-form>
            <input type="text" class="chat-input" name="mensaje" placeholder="Escribe tu mensaje…"
              autocomplete="off" aria-label="Tu mensaje" required />
            <button type="submit" class="chat-send" aria-label="Enviar">
              <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M3 11l18-8-8 18-2-7-8-3Z" stroke="currentColor" stroke-width="1.8" fill="none" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>
        </div>

        <!-- 3) Panel de progreso del documento -->
        <aside class="docpanel" data-docpanel hidden>
          <div class="docpanel-head">
            <strong data-doc-nombre>Tu documento</strong>
            <span class="docpanel-sub">Datos que vamos preparando</span>
          </div>
          <ul class="docpanel-list" data-doc-list></ul>
          <div class="docpanel-done" data-doc-done hidden>
            <p class="docpanel-done-msg">Tu documento quedó completo. Revisa que todo esté correcto y continúa al pago para generarlo.</p>
            <button type="button" class="btn btn-primary docpanel-btn" data-doc-pay>
              Pagar y generar contrato
            </button>
            <p class="docpanel-pay-note">Pago seguro con Mercado Pago · tarjeta, SPEI u OXXO, sin crear cuenta.</p>
            <p class="docpanel-status" data-doc-status hidden></p>
          </div>
        </aside>
      </div>

      <!-- 4) Retorno del pago (al volver por back_url con ?orden=) -->
      <div class="payret" data-payret hidden>
        <div class="payret-spin" data-payret-spin aria-hidden="true"></div>
        <h2 class="payret-title" data-payret-title>Confirmando tu pago…</h2>
        <p class="payret-msg" data-payret-msg>Un momento, estamos verificando tu pago con Mercado Pago.</p>
        <a href="/contratos/" class="btn btn-primary payret-back" data-payret-back hidden>Volver al asistente</a>
      </div>

    </div>
  </div>
</section>

<style>
  .asistente { padding-block: 3rem 2rem; }
  @media (min-width: 1024px) { .asistente { padding-block: 4.5rem 2.5rem; } }

  .asistente-title { max-width: 20ch; margin: 1.1rem 0 1rem; }
  .asistente-lead { max-width: 42rem; margin-bottom: 2rem; }

  .asistente-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card);
    overflow: hidden;
  }

  /* ---------- Gate ---------- */
  .gate { padding: 1.75rem; }
  @media (min-width: 768px) { .gate { padding: 2.5rem; } }
  .gate-head { margin-bottom: 1.5rem; }
  .gate-title { font-size: var(--text-xl); margin: 0 0 0.4rem; }
  .gate-note { font-size: var(--text-sm); color: var(--color-muted); margin: 0; max-width: 44rem; }
  .gate-note strong { color: var(--color-foreground-strong); }

  .gate-form { display: grid; grid-template-columns: 1fr; gap: 1rem; max-width: 30rem; }
  @media (min-width: 720px) { .gate-form { grid-template-columns: 1fr 1fr; max-width: none; } }
  .gf-field { display: flex; flex-direction: column; gap: 0.35rem; }
  .gf-field:first-child { grid-column: 1 / -1; }
  .gf-field label { font-size: var(--text-sm); font-weight: 600; color: var(--color-foreground-strong); }
  .gf-field input {
    font-family: inherit; font-size: var(--text-base);
    padding: 0.7rem 0.85rem; border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm); background: var(--color-surface); width: 100%;
  }
  .gf-field input:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 1px; }
  .gf-field input[aria-invalid="true"] { border-color: var(--color-alert); }

  .gf-error {
    grid-column: 1 / -1; margin: 0;
    font-size: var(--text-sm); color: var(--color-alert); font-weight: 600;
  }
  .gate-btn { grid-column: 1 / -1; justify-self: start; margin-top: 0.25rem; }
  .gate-legal { grid-column: 1 / -1; font-size: var(--text-xs); color: var(--color-muted-soft); margin: 0; }

  /* ---------- Chat + panel ---------- */
  .chat-wrap { display: flex; flex-direction: column; }
  .chat-wrap[hidden] { display: none; }

  .chat { display: flex; flex-direction: column; min-height: 28rem; }

  .chat-head {
    display: flex; align-items: center; justify-content: space-between; gap: 1rem;
    padding: 1rem 1.25rem; border-bottom: 1px solid var(--color-divider);
    background: var(--color-surface-alt);
  }
  .chat-id { display: flex; align-items: center; gap: 0.7rem; }
  .chat-dot { width: 9px; height: 9px; border-radius: 50%; background: var(--color-success); flex-shrink: 0; }
  .chat-id strong { display: block; font-size: var(--text-sm); color: var(--color-foreground-strong); }
  .chat-id span { font-size: var(--text-xs); color: var(--color-muted); }
  .chat-wa {
    display: inline-flex; align-items: center; gap: 0.4rem; flex-shrink: 0;
    font-size: var(--text-sm); font-weight: 600; color: var(--color-success);
    text-decoration: none; padding: 0.4rem 0.7rem; border-radius: var(--radius-sm);
    border: 1px solid var(--color-success);
  }
  .chat-wa:hover { background: var(--color-success); color: #fff; }

  .chat-log {
    flex: 1; display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.5rem 1.25rem; overflow-y: auto; max-height: 26rem;
  }
  .chat-msg {
    font-size: var(--text-sm); line-height: 1.55;
    padding: 0.75rem 1rem; border-radius: var(--radius-md); max-width: 85%;
  }
  .chat-msg--bot { background: var(--color-surface-alt); color: var(--color-foreground); align-self: flex-start; border-bottom-left-radius: var(--radius-xs); }
  .chat-msg--user { background: var(--color-accent); color: var(--color-on-accent); align-self: flex-end; border-bottom-right-radius: var(--radius-xs); }
  .chat-msg :global(a) { color: inherit; font-weight: 700; text-decoration: underline; }
  .chat-typing { opacity: 0.55; letter-spacing: 0.25em; }

  .chat-form { display: flex; gap: 0.5rem; padding: 1rem 1.25rem; border-top: 1px solid var(--color-divider); }
  .chat-input {
    flex: 1; min-width: 0; font-family: inherit; font-size: var(--text-base);
    padding: 0.7rem 0.9rem; border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm); background: var(--color-surface);
  }
  .chat-input:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 1px; }
  .chat-send {
    display: inline-flex; align-items: center; justify-content: center; width: 46px; flex-shrink: 0;
    background: var(--color-accent); color: var(--color-on-accent); border: none;
    border-radius: var(--radius-sm); cursor: pointer; transition: background 200ms ease;
  }
  .chat-send:hover { background: var(--color-accent-hover); }

  /* ---------- Panel de progreso ---------- */
  .docpanel { border-top: 1px solid var(--color-divider); background: var(--color-surface-alt); padding: 1.25rem; }
  .docpanel[hidden] { display: none; }
  .docpanel-head { display: flex; flex-direction: column; gap: 0.1rem; margin-bottom: 0.9rem; }
  .docpanel-head strong { font-size: var(--text-base); color: var(--color-foreground-strong); }
  .docpanel-sub { font-size: var(--text-xs); color: var(--color-muted); }

  /* Los .dp-* los inyecta el script con innerHTML, así que el scope de Astro no
     los alcanza: se anclan con :global() bajo .docpanel-list (que sí es estático). */
  .docpanel-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.65rem; }
  .docpanel-list :global(.dp-item) { display: grid; grid-template-columns: 1.25rem 1fr; gap: 0.5rem; align-items: start; font-size: var(--text-sm); }
  .docpanel-list :global(.dp-mark) {
    width: 1.05rem; height: 1.05rem; margin-top: 0.1rem; border-radius: 50%;
    border: 1.5px solid var(--color-border-strong); flex-shrink: 0;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.7rem; line-height: 1; color: transparent;
  }
  .docpanel-list :global(.dp-item.is-done .dp-mark) { background: var(--color-success); border-color: var(--color-success); color: #fff; }
  .docpanel-list :global(.dp-text) { display: flex; flex-direction: column; gap: 0.1rem; min-width: 0; }
  .docpanel-list :global(.dp-label) { color: var(--color-muted); line-height: 1.35; }
  .docpanel-list :global(.dp-item.is-done .dp-label) { color: var(--color-foreground); }
  .docpanel-list :global(.dp-value) { color: var(--color-foreground-strong); font-weight: 600; word-break: break-word; }

  .docpanel-done { margin-top: 1.1rem; padding-top: 1rem; border-top: 1px dashed var(--color-divider); }
  .docpanel-done[hidden] { display: none; }
  .docpanel-done-msg { font-size: var(--text-sm); color: var(--color-foreground); margin: 0 0 0.8rem; }
  .docpanel-btn { width: 100%; justify-content: center; }
  .docpanel-btn:disabled { opacity: 0.6; cursor: default; }
  .docpanel-status { font-size: var(--text-sm); font-weight: 600; margin: 0.7rem 0 0; }
  .docpanel-status[hidden] { display: none; }
  .docpanel-status.is-ok { color: var(--color-success); }
  .docpanel-status.is-err { color: var(--color-alert); }
  .docpanel-pay-note { font-size: var(--text-xs); color: var(--color-muted); margin: 0.55rem 0 0; }

  /* ---------- Retorno del pago ---------- */
  .payret { padding: 3rem 1.75rem; text-align: center; }
  .payret[hidden] { display: none; }
  .payret-spin {
    width: 2.5rem; height: 2.5rem; margin: 0 auto 1.25rem; border-radius: 50%;
    border: 3px solid var(--color-border); border-top-color: var(--color-accent);
    animation: payret-spin 0.8s linear infinite;
  }
  .payret.is-ok .payret-spin, .payret.is-err .payret-spin { display: none; }
  @keyframes payret-spin { to { transform: rotate(360deg); } }
  .payret-title { font-size: var(--text-xl); margin: 0 0 0.5rem; }
  .payret.is-ok .payret-title { color: var(--color-success); }
  .payret.is-err .payret-title { color: var(--color-alert); }
  .payret-msg { font-size: var(--text-base); color: var(--color-muted); margin: 0 auto; max-width: 34rem; }
  .payret-back { margin-top: 1.5rem; }
  .payret-back[hidden] { display: none; }
</style>

<script>
  import { business } from '../../data/business';

  type Campo = { clave: string; etiqueta: string; tipo: string; obligatorio: boolean; activo: boolean; lleno: boolean; valor: string; opciones?: string[] };
  type Estado = { documento_id: string | null; documento_nombre: string | null; valores: Record<string, string>; campos: Campo[]; completo: boolean };

  const root = document.querySelector<HTMLElement>('[data-asistente]');
  if (root) {
    const gate = root.querySelector<HTMLElement>('[data-gate]')!;
    const gateForm = root.querySelector<HTMLFormElement>('[data-gate-form]')!;
    const gateError = root.querySelector<HTMLElement>('[data-gate-error]')!;
    const chat = root.querySelector<HTMLElement>('[data-chat]')!;
    const log = root.querySelector<HTMLElement>('[data-chat-log]')!;
    const chatForm = root.querySelector<HTMLFormElement>('[data-chat-form]')!;
    const chatInput = root.querySelector<HTMLInputElement>('.chat-input')!;

    const docpanel = root.querySelector<HTMLElement>('[data-docpanel]')!;
    const docNombre = root.querySelector<HTMLElement>('[data-doc-nombre]')!;
    const docList = root.querySelector<HTMLElement>('[data-doc-list]')!;
    const docDone = root.querySelector<HTMLElement>('[data-doc-done]')!;
    const docPay = root.querySelector<HTMLButtonElement>('[data-doc-pay]')!;
    const docStatus = root.querySelector<HTMLElement>('[data-doc-status]')!;

    const payret = root.querySelector<HTMLElement>('[data-payret]')!;
    const payTitle = root.querySelector<HTMLElement>('[data-payret-title]')!;
    const payMsg = root.querySelector<HTMLElement>('[data-payret-msg]')!;
    const payBack = root.querySelector<HTMLElement>('[data-payret-back]')!;

    let lead: { nombre: string; telefono: string; correo: string } | null = null;
    const historial: { role: 'user' | 'assistant'; content: string }[] = [];
    let estado: Estado = { documento_id: null, documento_nombre: null, valores: {}, campos: [], completo: false };

    const escapeHtml = (s: string) => s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    const linkify = (t: string) =>
      escapeHtml(t).replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener">$1</a>');
    const truncar = (s: string, n: number) => (s.length > n ? s.slice(0, n - 1) + '…' : s);

    const addMsg = (text: string, who: 'bot' | 'user') => {
      const el = document.createElement('div');
      el.className = `chat-msg chat-msg--${who}`;
      if (who === 'user') el.textContent = text; else el.innerHTML = linkify(text);
      log.appendChild(el);
      log.scrollTop = log.scrollHeight;
    };

    // ── Panel de progreso ──
    const renderPanel = () => {
      if (!estado.documento_id) { docpanel.hidden = true; return; }
      docpanel.hidden = false;
      docNombre.textContent = estado.documento_nombre || 'Tu documento';

      const activos = (estado.campos || []).filter((c) => c.activo);
      docList.innerHTML = activos.map((c) => {
        const etiqueta = c.etiqueta.replace(/[¿?:]+$/g, '').trim();
        const valor = c.lleno ? `<span class="dp-value">${escapeHtml(truncar(c.valor, 90))}</span>` : '';
        return `<li class="dp-item${c.lleno ? ' is-done' : ''}">` +
          `<span class="dp-mark" aria-hidden="true">✓</span>` +
          `<span class="dp-text"><span class="dp-label">${escapeHtml(etiqueta)}</span>${valor}</span></li>`;
      }).join('');

      docDone.hidden = !estado.completo;
    };

    // ── Registro de lead ──
    gateForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const data = new FormData(gateForm);
      const nombre = String(data.get('nombre') || '').trim();
      const telefono = String(data.get('telefono') || '').trim();
      const correo = String(data.get('correo') || '').trim();

      const telDigits = telefono.replace(/\D/g, '');
      const emailOk = /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(correo);
      let err = '';
      if (!nombre) err = 'Escribe tu nombre.';
      else if (telDigits.length < 10) err = 'Escribe un teléfono válido (10 dígitos).';
      else if (!emailOk) err = 'Escribe un correo electrónico válido.';

      gateError.hidden = !err;
      gateError.textContent = err;
      if (err) return;

      lead = { nombre, telefono, correo };
      // Registra el lead (ClickUp + correo) en segundo plano; no bloquea la conversación.
      fetch('/.netlify/functions/registrar-lead', {
        method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify(lead)
      }).catch(() => {});

      gate.hidden = true;
      chat.hidden = false;

      const nombreCorto = nombre.split(' ')[0];
      const saludo = `Hola ${nombreCorto}, gusto en saludarle. Soy el asistente de Grupo LGO y le ayudo a preparar su documento. Para empezar: ¿ya sabe qué documento necesita, o prefiere contarme su situación y le recomiendo el adecuado?`;
      addMsg(saludo, 'bot');
      historial.push({ role: 'assistant', content: saludo });
      chatInput.focus();
    });

    // ── Envío de mensajes → función de chat (Claude) ──
    chatForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msg = chatInput.value.trim();
      if (!msg) return;
      addMsg(msg, 'user');
      chatInput.value = '';
      chatInput.disabled = true;

      const typing = document.createElement('div');
      typing.className = 'chat-msg chat-msg--bot chat-typing';
      typing.textContent = '…';
      log.appendChild(typing);
      log.scrollTop = log.scrollHeight;

      try {
        const r = await fetch('/.netlify/functions/chat', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({
            mensaje: msg,
            historial,
            estado: { documento_id: estado.documento_id, valores: estado.valores }
          })
        });
        const data = await r.json().catch(() => ({}));
        typing.remove();
        const reply = r.ok
          ? (data.reply || '…')
          : (data.error || `Tuvimos un problema. Si prefiere, escríbanos por WhatsApp: ${business.whatsappUrl}`);
        addMsg(reply, 'bot');
        historial.push({ role: 'user', content: msg }, { role: 'assistant', content: reply });
        if (r.ok && data.estado) { estado = data.estado as Estado; renderPanel(); }
      } catch {
        typing.remove();
        addMsg(`Tuvimos un problema de conexión. Si prefiere, escríbanos por WhatsApp: ${business.whatsappUrl}`, 'bot');
      } finally {
        chatInput.disabled = false;
        chatInput.focus();
      }
    });

    // ── Pagar y generar: crea la preferencia y redirige a Checkout Pro ──
    docPay.addEventListener('click', async () => {
      if (!lead || !estado.documento_id) return;
      docPay.disabled = true;
      docStatus.hidden = false;
      docStatus.className = 'docpanel-status';
      docStatus.textContent = 'Abriendo el pago seguro…';
      try {
        const r = await fetch('/.netlify/functions/mp-crear-preferencia', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ contrato_id: estado.documento_id, valores: estado.valores, lead })
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.init_point) {
          try { sessionStorage.setItem('lgo_orden', data.orden_id); } catch {}
          window.location.href = data.init_point;
        } else {
          throw new Error(data.error || 'fallo');
        }
      } catch {
        docPay.disabled = false;
        docStatus.className = 'docpanel-status is-err';
        docStatus.textContent = `No se pudo iniciar el pago. Intenta de nuevo o escríbenos por WhatsApp: ${business.whatsappUrl}`;
      }
    });

    // ── Retorno del pago (al volver por back_url ?orden=...) ──
    const params = new URLSearchParams(window.location.search);
    let ordenUrl = params.get('orden');
    if (!ordenUrl) { try { ordenUrl = sessionStorage.getItem('lgo_orden'); } catch {} }
    if (ordenUrl) manejarRetornoPago(ordenUrl, params.get('payment_id'));

    function finPago(tipo: 'ok' | 'err', titulo: string, msg: string) {
      payret.className = `payret is-${tipo}`;
      payTitle.textContent = titulo;
      payMsg.textContent = msg;
      payBack.hidden = false;
      try { sessionStorage.removeItem('lgo_orden'); } catch {}
    }

    async function manejarRetornoPago(ordenId: string, paymentId: string | null) {
      gate.hidden = true;
      chat.hidden = true;
      payret.hidden = false;
      payret.className = 'payret';
      payTitle.textContent = 'Confirmando tu pago…';
      payMsg.textContent = 'Un momento, estamos verificando tu pago con Mercado Pago.';

      // El pago puede tardar en aprobarse: reintenta el estado unas veces.
      let token: string | null = null;
      for (let i = 0; i < 5; i++) {
        try {
          const r = await fetch('/.netlify/functions/mp-estado', {
            method: 'POST', headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ orden_id: ordenId, payment_id: paymentId })
          });
          const data = await r.json().catch(() => ({}));
          if (data.pagado && data.token) { token = data.token; break; }
          if (data.status === 'consumed') {
            finPago('ok', 'Este pago ya se procesó', 'Tu documento ya está en proceso con un abogado de Grupo LGO. Te contactaremos en breve.');
            return;
          }
        } catch {}
        await new Promise((res) => setTimeout(res, 1800));
      }

      if (!token) {
        finPago('err', 'No pudimos confirmar el pago', `Si ya pagaste, espera un momento y recarga la página. Si el problema continúa, escríbenos por WhatsApp: ${business.whatsappUrl}`);
        return;
      }

      // Pago confirmado → entrega (interino: envío al despacho, blindado por token).
      try {
        const r = await fetch('/.netlify/functions/registrar-documento', {
          method: 'POST', headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ orden_id: ordenId, token })
        });
        const data = await r.json().catch(() => ({}));
        if (r.ok && data.ok) {
          finPago('ok', '¡Pago confirmado!', 'Tu documento quedó pagado y registrado. Un abogado de Grupo LGO te lo entregará en breve. Gracias por tu confianza.');
        } else {
          throw new Error(data.error || 'fallo');
        }
      } catch {
        finPago('err', 'Pago confirmado, con un detalle al entregar', `Tu pago se realizó correctamente. Si no recibes tu documento pronto, escríbenos por WhatsApp: ${business.whatsappUrl}`);
      }
    }
  }
</script>
