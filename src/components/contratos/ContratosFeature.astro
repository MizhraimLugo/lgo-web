---
// Ficha destacada de /contratos para reutilizar en Inicio y LGO Abogados.
// Diseño nativo (tokens LGO): tarjeta con panel de acento + stack de documentos.
export interface Props {
  eyebrow?: string;
  title?: string;
  body?: string;
}
const {
  eyebrow = 'Nuevo · Documentos legales',
  title = 'Tus contratos, listos para firmar en minutos.',
  body = 'Describe tu situación a nuestro asistente y prepara el documento que necesitas — redactado por Grupo LGO y listo para descargar.'
} = Astro.props;

const ejemplos = ['Arrendamiento', 'Compraventa', 'Poderes', 'Pagaré', 'Confidencialidad', 'Prestación de servicios'];
---
<section class="cf">
  <div class="container-base">
    <div class="cf-card reveal-up">
      <div class="cf-text">
        <span class="eyebrow">{eyebrow}</span>
        <h2 class="cf-title">{title}</h2>
        <p class="cf-body">{body}</p>
        <ul class="cf-chips">
          {ejemplos.map((e) => <li>{e}</li>)}
        </ul>
        <a href="/contratos/" class="btn btn-primary cf-cta">Ir a Contratos →</a>
      </div>

      <div class="cf-visual" aria-hidden="true">
        <div class="cf-doc cf-doc--back"></div>
        <div class="cf-doc cf-doc--mid"></div>
        <div class="cf-doc cf-doc--front">
          <span class="cf-doc-badge"></span>
          <span class="cf-doc-line cf-doc-line--title"></span>
          <span class="cf-doc-line"></span>
          <span class="cf-doc-line cf-doc-line--short"></span>
          <span class="cf-doc-line"></span>
          <span class="cf-doc-line cf-doc-line--short"></span>
          <span class="cf-doc-sign"></span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cf { padding-block: 3rem; }
  @media (min-width: 1024px) { .cf { padding-block: 4rem; } }

  .cf-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    background: var(--color-foreground-strong);
    color: var(--color-on-dark);
    border-radius: var(--radius-lg);
    padding: 2.25rem;
    overflow: hidden;
  }
  /* filete de acento superior */
  .cf-card::before {
    content: '';
    position: absolute; inset: 0 0 auto 0; height: 4px;
    background: var(--color-accent);
  }
  @media (min-width: 880px) {
    .cf-card {
      grid-template-columns: 1.3fr 1fr;
      align-items: center;
      gap: 3rem;
      padding: 3rem 3.25rem;
    }
  }

  .cf-text .eyebrow { color: var(--color-accent-soft); }
  .cf-text .eyebrow::before { background: var(--color-accent-soft); }

  .cf-title {
    color: var(--color-on-dark);
    font-size: var(--text-3xl);
    margin: 1rem 0 0.85rem;
    max-width: 18ch;
    letter-spacing: -0.018em;
  }
  .cf-body {
    color: rgba(250, 248, 244, 0.82);
    font-size: var(--text-base);
    line-height: 1.6;
    max-width: 44ch;
    margin: 0 0 1.25rem;
  }

  .cf-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.75rem;
  }
  .cf-chips li {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-on-dark);
    padding: 0.35rem 0.7rem;
    border: 1px solid rgba(250, 248, 244, 0.22);
    border-radius: 999px;
    white-space: nowrap;
  }

  .cf-cta { box-shadow: 0 10px 24px -10px rgba(212, 84, 26, 0.7); }

  /* ---------- Visual: stack de documentos ---------- */
  .cf-visual {
    position: relative;
    height: 14rem;
    display: none;
  }
  @media (min-width: 880px) { .cf-visual { display: block; } }

  .cf-doc {
    position: absolute;
    width: 11rem;
    height: 13.5rem;
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    box-shadow: 0 18px 40px -18px rgba(0, 0, 0, 0.55);
  }
  .cf-doc--back  { right: 1.5rem; top: 1.2rem; transform: rotate(7deg);  background: var(--color-gray-200); }
  .cf-doc--mid   { right: 3rem;   top: 0.6rem; transform: rotate(-4deg); background: var(--color-gray-100); }
  .cf-doc--front {
    right: 2.25rem; top: 0;
    display: flex; flex-direction: column; gap: 0.6rem;
    padding: 1.1rem 1.2rem;
    border-top: 3px solid var(--color-accent);
  }
  .cf-doc-badge {
    width: 2.2rem; height: 0.55rem; border-radius: 2px;
    background: var(--color-accent); margin-bottom: 0.4rem;
  }
  .cf-doc-line { height: 0.5rem; border-radius: 2px; background: var(--color-gray-150); }
  .cf-doc-line--title { height: 0.7rem; width: 80%; background: var(--color-gray-300); }
  .cf-doc-line--short { width: 55%; }
  .cf-doc-sign {
    margin-top: auto; width: 4.5rem; height: 1.4rem;
    border-bottom: 2px solid var(--color-gray-300);
    background:
      radial-gradient(circle at 20% 60%, var(--color-accent) 0 2px, transparent 2px) 0 0/100% 100%;
    -webkit-mask: linear-gradient(#000 0 0);
  }

  @media (prefers-reduced-motion: no-preference) {
    .cf-doc { transition: transform 400ms cubic-bezier(0.16,1,0.3,1); }
    .cf-card:hover .cf-doc--front { transform: translateY(-6px); }
    .cf-card:hover .cf-doc--back  { transform: rotate(9deg) translateY(-2px); }
    .cf-card:hover .cf-doc--mid   { transform: rotate(-6deg) translateY(-3px); }
  }
</style>
