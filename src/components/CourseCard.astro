---
import type { Course } from '@data/cursos-preview';

export interface Props {
  course: Course;
  layout?: 'standard' | 'featured';   // featured = ancho completo, horizontal en desktop
}

const { course, layout = 'standard' } = Astro.props;
const isFeatured = layout === 'featured';
---
<a class={`course-card course-card--${layout}`} href={course.url} data-format={course.format}>
  <div class="course-meta">
    <span class={`course-badge course-badge--${course.format}`}>{course.formatLabel}</span>
  </div>

  <div class="course-body">
    <h3 class="course-title">{course.name}</h3>
    <p class="course-audience"><strong>Para:</strong> {course.audience}</p>
    <p class="course-blurb">{course.blurb}</p>
  </div>

  <div class="course-footer">
    <span class="course-cta">{course.cta} →</span>
  </div>
</a>

<style>
  .course-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding: 1.75rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-accent);
    border-radius: var(--radius-sm);
    text-decoration: none;
    color: inherit;
    transition: border-color 200ms ease, box-shadow 200ms ease, transform 200ms ease;
    min-height: 240px;
  }
  .course-card:hover {
    box-shadow: var(--shadow-soft);
    transform: translateY(-2px);
    border-top-color: var(--color-accent-deep);
  }

  /* Featured: layout horizontal en desktop, distinto visualmente */
  .course-card--featured {
    background: var(--color-surface);
    padding: 2.25rem;
    min-height: 0;
  }
  @media (min-width: 900px) {
    .course-card--featured {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem 3rem;
      align-items: center;
      padding: 2.5rem 3rem;
    }
    .course-card--featured .course-meta { grid-column: 1; align-self: start; }
    .course-card--featured .course-body { grid-column: 1; }
    .course-card--featured .course-footer {
      grid-column: 2;
      grid-row: 1 / span 3;
      align-self: center;
      justify-self: end;
    }
  }

  .course-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .course-badge {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-eyebrow);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    font-weight: 700;
    padding: 0.35rem 0.65rem;
    border-radius: var(--radius-xs);
  }
  .course-badge--gratuito {
    background: var(--color-accent-soft);
    color: var(--color-accent-deep);
  }
  .course-badge--online {
    background: var(--color-surface-band);
    color: var(--color-foreground-strong);
    border: 1px solid var(--color-border);
  }
  .course-badge--presencial {
    background: var(--color-foreground-strong);
    color: var(--color-on-dark);
  }

  .course-body {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .course-title {
    font-size: 1.25rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.012em;
    color: var(--color-foreground-strong);
    margin: 0;
  }
  .course-card--featured .course-title {
    font-size: 1.625rem;
    line-height: 1.18;
    letter-spacing: -0.018em;
  }

  .course-audience {
    font-size: var(--text-xs);
    color: var(--color-muted);
    margin: 0;
    line-height: 1.5;
  }
  .course-audience strong {
    color: var(--color-foreground-strong);
    font-weight: 700;
  }

  .course-blurb {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }
  .course-card--featured .course-blurb {
    font-size: 1rem;
    line-height: 1.65;
  }

  .course-footer {
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-divider);
    margin-top: auto;
  }
  .course-card--featured .course-footer {
    border-top: none;
    padding-top: 0;
  }

  .course-cta {
    display: inline-flex;
    align-items: center;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-accent);
  }
  .course-card--featured .course-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0.75rem 1.75rem;
    background: var(--color-accent);
    color: var(--color-on-accent);
    border-radius: var(--radius-sm);
    transition: background 200ms ease;
  }
  .course-card--featured:hover .course-cta {
    background: var(--color-accent-hover);
  }
</style>
